<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Night theme - identical to day theme since app forces dark mode -->
    <style name="Theme.A2U" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Primary brand color - white for dark theme -->
        <item name="colorPrimary">@color/white</item>
        <item name="colorPrimaryVariant">@color/white</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="a2uMidiAccent">@color/midi_accent</item>
        <item name="a2uMusicAccent">@color/music_accent</item>
        <item name="a2uMusicAccentDim">@color/music_accent_dim</item>
        <item name="colorSecondary">?attr/a2uMidiAccent</item>
        <item name="colorSecondaryVariant">?attr/a2uMidiAccent</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Force dark text colors for readability on dark backgrounds -->
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">#B3B3B3</item>
        <item name="colorAccent">?attr/a2uMidiAccent</item>
        <item name="android:colorAccent">?attr/a2uMidiAccent</item>
        <!-- Background colors -->
        <item name="android:windowBackground">@color/startup_background</item>
        <item name="android:colorBackground">@color/startup_background</item>
        <!-- Dialog button style - white text for both AlertDialog and MaterialAlertDialog -->
        <item name="materialAlertDialogTheme">@style/Theme.A2U.MaterialAlertDialog</item>
        <item name="alertDialogTheme">@style/Theme.A2U.AlertDialog</item>
        <item name="android:alertDialogTheme">@style/Theme.A2U.AlertDialog</item>
    </style>

    <style name="Theme.A2U.Green" parent="Theme.A2U">
        <item name="a2uMidiAccent">@color/theme_green_midi_accent</item>
        <item name="a2uMusicAccent">@color/theme_green_music_accent</item>
        <item name="a2uMusicAccentDim">@color/theme_green_music_accent_dim</item>
    </style>

    <style name="Theme.A2U.Turquoise" parent="Theme.A2U">
        <item name="a2uMidiAccent">@color/theme_turquoise_midi_accent</item>
        <item name="a2uMusicAccent">@color/theme_turquoise_music_accent</item>
        <item name="a2uMusicAccentDim">@color/theme_turquoise_music_accent_dim</item>
    </style>

    <style name="Theme.A2U.Classic" parent="Theme.A2U">
        <item name="a2uMidiAccent">@color/theme_classic_midi_accent</item>
        <item name="a2uMusicAccent">@color/theme_classic_music_accent</item>
        <item name="a2uMusicAccentDim">@color/theme_classic_music_accent_dim</item>
    </style>

    <style name="Theme.A2U.Orange" parent="Theme.A2U">
        <item name="a2uMidiAccent">@color/theme_orange_midi_accent</item>
        <item name="a2uMusicAccent">@color/theme_orange_music_accent</item>
        <item name="a2uMusicAccentDim">@color/theme_orange_music_accent_dim</item>
    </style>

    <!-- MaterialAlertDialog theme with white buttons -->
    <style name="Theme.A2U.MaterialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/white</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
    </style>

    <!-- Standard AlertDialog theme with white buttons -->
    <style name="Theme.A2U.AlertDialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/white</item>
        <item name="colorAccent">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
    </style>

    <!-- Dialog button style -->
    <style name="Widget.A2U.Button.TextButton.Dialog" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Dialog theme for color pickers - also dark -->
    <style name="Theme_A2U_Dialog" parent="Theme.MaterialComponents.Dialog">
        <item name="a2uMidiAccent">@color/midi_accent</item>
        <item name="a2uMusicAccent">@color/music_accent</item>
        <item name="a2uMusicAccentDim">@color/music_accent_dim</item>
        <item name="colorPrimary">@color/white</item>
        <item name="colorPrimaryVariant">@color/white</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">?attr/a2uMidiAccent</item>
        <item name="colorSecondaryVariant">?attr/a2uMidiAccent</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">#B3B3B3</item>
        <item name="android:windowBackground">@color/startup_background</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
    </style>
</resources>
