    <string name="about_description_title">O A2U</string>
    <string name="about_description">A2U to kompleksowe centrum audio dla Androida, łączące wiele funkcji audio w jednej aplikacji:\n\n• Odtwarzacz muzyki z zarządzaniem biblioteką, playlistami, ulubionymi, edycją tagów ID3 i synchronizacją w chmurze\n• Odtwarzacz MIDI z syntezą SoundFont, trybem ćwiczenia z opadającymi nutami i obsługą zewnętrznej klawiatury\n• Radio internetowe ze stacjami i ulubionymi\n• Edytor audio do przycinania i podstawowej edycji\n• Pełnowartościowy kreator/edytor SoundFont SF2</string>
    <string name="about_credits_title">Podziękowania</string>
    <string name="about_credits_subtitle">A2U wykorzystuje następujące biblioteki open source:</string>
    <string name="about_credit_mididriver_name">MidiDriver</string>
    <string name="about_credit_mididriver_desc">Autor: Bill Farmer — Wrapper sterownika MIDI dla Sonivox EAS na Androida. Licencja Apache 2.0.</string>
    <string name="about_credit_sonivox_name">Sonivox EAS</string>
    <string name="about_credit_sonivox_desc">Autor: Sonic Network Inc. — Wbudowany silnik syntezy audio do odtwarzania MIDI. Licencja Apache 2.0.</string>
    <string name="about_credit_jaudiotagger_name">JAudioTagger</string>
    <string name="about_credit_jaudiotagger_desc">Autorzy: Raphaël Slinckx i in. — Biblioteka Java do odczytu i zapisu metadanych plików audio (tagi ID3). Licencja LGPL.</string>
    <string name="about_credit_midilib_name">android-midi-lib</string>
    <string name="about_credit_midilib_desc">Autor: LeffelMania — Parser plików MIDI dla Androida. Licencja Apache 2.0.</string>
    <string name="about_credit_ffmpeg_name">FFmpeg-kit</string>
    <string name="about_credit_ffmpeg_desc">Autor: Arthenica — Wrapper FFmpeg dla platform mobilnych, używany do przetwarzania audio. Licencja LGPL 3.0.</string>
    <string name="about_credit_exoplayer_name">Media3 ExoPlayer</string>
    <string name="about_credit_exoplayer_desc">Autor: Google — Potężny odtwarzacz multimedialny dla Androida, używany do odtwarzania muzyki i radia. Licencja Apache 2.0.</string>
    <string name="about_credit_okhttp_name">OkHttp</string>
    <string name="about_credit_okhttp_desc">Autor: Square — Klient HTTP do żądań sieciowych. Licencja Apache 2.0.</string>
    <string name="about_credit_fluidsynth_name">FluidSynth</string>
    <string name="about_credit_fluidsynth_desc">Autor: społeczność FluidSynth — Syntezator programowy czasu rzeczywistego oparty na specyfikacji SoundFont 2. Licencja LGPL 2.1.</string>
    <string name="about_license_notice">Wszystkie biblioteki są używane zgodnie z ich licencjami.\nDziękujemy wszystkim współtwórcom open source!</string>
    <string name="about_privacy_title">Prywatność i uprawnienia</string>
    <string name="about_privacy_microphone">A2U prosi o dostęp do mikrofonu w dwóch konkretnych celach:\n\n• Nagrywanie audio w Edytorze audio i Kreatorze SoundFont\n• Wizualizacja spektrum częstotliwości w czasie rzeczywistym w Odtwarzaczu muzyki (aplikacja nasłuchuje wyjścia audio, aby wyświetlić krzywe częstotliwości)\n\nMikrofon nigdy nie jest używany do innych celów. Żadne audio nie jest nagrywane, przesyłane ani przechowywane bez Twojego wyraźnego działania w Edytorze audio lub Kreatorze SoundFont.</string>
