    <string name="permission_notification_title">Włącz powiadomienia</string>
    <string name="permission_notification_message">A2U potrzebuje dostępu do powiadomień, aby wyświetlać elementy sterowania odtwarzaniem na ekranie blokady i pasku stanu (radio, muzyka).\n\nBez tego uprawnienia odtwarzanie w tle nadal będzie działać, ale nie będzie można go kontrolować spoza aplikacji.</string>
    <string name="permission_dialog_title">Wymagane uprawnienia</string>
    <string name="permission_dialog_message">A2U potrzebuje dostępu do plików audio, aby wyświetlić bibliotekę muzyki, odtwarzać utwory i synchronizować liczbę odtworzeń.\n\nTo uprawnienie jest niezbędne do prawidłowego działania aplikacji.</string>
    <string name="permission_dialog_grant">Udziel dostępu</string>
    <string name="permission_dialog_later">Później</string>
    <string name="permission_rationale_message">Bez dostępu do plików audio A2U nie może wyświetlić biblioteki muzyki ani odtwarzać utworów.\n\nProszę udzielić uprawnienia, aby korzystać z aplikacji.</string>
    <string name="permission_denied_title">Odmówiono uprawnień</string>
    <string name="permission_denied_message">Możesz udzielić uprawnienia później w ustawieniach aplikacji, gdy wejdziesz do odtwarzacza Muzyki lub MIDI.</string>
