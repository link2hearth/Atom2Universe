<resources>
    <string name="permission_notification_title">Meldingen inschakelen</string>
    <string name="permission_notification_message">A2U heeft toegang tot meldingen nodig om afspeelbedieningen op het vergrendelingsscherm en in de statusbalk weer te geven (radio, muziek).\n\nZonder deze toestemming werkt achtergrondweergave nog steeds, maar u kunt deze niet van buiten de app bedienen.</string>
    <string name="permission_dialog_title">Toestemming vereist</string>
    <string name="permission_dialog_message">A2U heeft toegang tot uw audiobestanden nodig om uw muziekbibliotheek weer te geven, uw nummers af te spelen en uw afspeeltellingen te synchroniseren.\n\nDeze toestemming is essentieel voor de werking van de app.</string>
    <string name="permission_dialog_grant">Toegang verlenen</string>
    <string name="permission_dialog_later">Later</string>
    <string name="permission_rationale_message">Zonder toegang tot audiobestanden kan A2U uw muziekbibliotheek niet weergeven of uw nummers afspelen.\n\nVerleen de toestemming om de app te gebruiken.</string>
    <string name="permission_denied_title">Toestemming geweigerd</string>
    <string name="permission_denied_message">U kunt de toestemming later verlenen via de app-instellingen wanneer u de Muziek- of MIDI-speler opent.</string>
