<resources>
    <!-- Base application theme - DARK theme forced (app uses dark backgrounds everywhere) -->
    <style name="Theme.A2U" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Primary brand color - white for dark theme -->
        <item name="colorPrimary">@color/white</item>
        <item name="colorPrimaryVariant">@color/white</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="a2uMidiAccent">@color/midi_accent</item>
        <item name="a2uMidiAccentOnText">@color/accent_on_text_default</item>
        <item name="a2uMusicAccent">@color/music_accent</item>
        <item name="a2uMusicAccentDim">@color/music_accent_dim</item>
        <item name="colorSecondary">?attr/a2uMidiAccent</item>
        <item name="colorSecondaryVariant">?attr/a2uMidiAccent</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Force dark text colors for readability on dark backgrounds -->
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">#B3B3B3</item>
        <item name="colorAccent">?attr/a2uMidiAccent</item>
        <item name="android:colorAccent">?attr/a2uMidiAccent</item>
        <!-- Background colors -->
        <item name="android:windowBackground">@color/startup_background</item>
        <item name="android:colorBackground">@color/startup_background</item>
        <!-- Dialog button style - white text for both AlertDialog and MaterialAlertDialog -->
        <item name="materialAlertDialogTheme">@style/Theme.A2U.MaterialAlertDialog</item>
        <item name="alertDialogTheme">@style/Theme.A2U.AlertDialog</item>
        <item name="android:alertDialogTheme">@style/Theme.A2U.AlertDialog</item>
    </style>

    <style name="Theme.A2U.Green" parent="Theme.A2U">
        <item name="a2uMidiAccent">@color/theme_green_midi_accent</item>
        <item name="a2uMidiAccentOnText">@color/accent_on_text_default</item>
        <item name="a2uMusicAccent">@color/theme_green_music_accent</item>
        <item name="a2uMusicAccentDim">@color/theme_green_music_accent_dim</item>
    </style>

    <style name="Theme.A2U.Turquoise" parent="Theme.A2U">
        <item name="a2uMidiAccent">@color/theme_turquoise_midi_accent</item>
        <item name="a2uMidiAccentOnText">@color/accent_on_text_default</item>
        <item name="a2uMusicAccent">@color/theme_turquoise_music_accent</item>
        <item name="a2uMusicAccentDim">@color/theme_turquoise_music_accent_dim</item>
    </style>

    <style name="Theme.A2U.Classic" parent="Theme.A2U">
        <item name="a2uMidiAccent">@color/theme_classic_midi_accent</item>
        <item name="a2uMidiAccentOnText">@color/theme_classic_midi_accent_on_text</item>
        <item name="a2uMusicAccent">@color/theme_classic_music_accent</item>
        <item name="a2uMusicAccentDim">@color/theme_classic_music_accent_dim</item>
    </style>

    <style name="Theme.A2U.Orange" parent="Theme.A2U">
        <item name="a2uMidiAccent">@color/theme_orange_midi_accent</item>
        <item name="a2uMidiAccentOnText">@color/accent_on_text_default</item>
        <item name="a2uMusicAccent">@color/theme_orange_music_accent</item>
        <item name="a2uMusicAccentDim">@color/theme_orange_music_accent_dim</item>
    </style>

    <style name="Theme.A2U.Purple" parent="Theme.A2U">
        <item name="a2uMidiAccent">@color/theme_purple_midi_accent</item>
        <item name="a2uMidiAccentOnText">@color/accent_on_text_default</item>
        <item name="a2uMusicAccent">@color/theme_purple_music_accent</item>
        <item name="a2uMusicAccentDim">@color/theme_purple_music_accent_dim</item>
    </style>

    <style name="Theme.A2U.Pink" parent="Theme.A2U">
        <item name="a2uMidiAccent">@color/theme_pink_midi_accent</item>
        <item name="a2uMidiAccentOnText">@color/accent_on_text_default</item>
        <item name="a2uMusicAccent">@color/theme_pink_music_accent</item>
        <item name="a2uMusicAccentDim">@color/theme_pink_music_accent_dim</item>
    </style>

    <style name="Theme.A2U.Blue" parent="Theme.A2U">
        <item name="a2uMidiAccent">@color/theme_blue_midi_accent</item>
        <item name="a2uMidiAccentOnText">@color/accent_on_text_default</item>
        <item name="a2uMusicAccent">@color/theme_blue_music_accent</item>
        <item name="a2uMusicAccentDim">@color/theme_blue_music_accent_dim</item>
    </style>

    <style name="Theme.A2U.Red" parent="Theme.A2U">
        <item name="a2uMidiAccent">@color/theme_red_midi_accent</item>
        <item name="a2uMidiAccentOnText">@color/accent_on_text_default</item>
        <item name="a2uMusicAccent">@color/theme_red_music_accent</item>
        <item name="a2uMusicAccentDim">@color/theme_red_music_accent_dim</item>
    </style>

    <style name="Theme.A2U.Indigo" parent="Theme.A2U">
        <item name="a2uMidiAccent">@color/theme_indigo_midi_accent</item>
        <item name="a2uMidiAccentOnText">@color/accent_on_text_default</item>
        <item name="a2uMusicAccent">@color/theme_indigo_music_accent</item>
        <item name="a2uMusicAccentDim">@color/theme_indigo_music_accent_dim</item>
    </style>

    <!-- MaterialAlertDialog theme with white buttons -->
    <style name="Theme.A2U.MaterialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/white</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
    </style>

    <!-- Standard AlertDialog theme with white buttons -->
    <style name="Theme.A2U.AlertDialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/white</item>
        <item name="colorAccent">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
    </style>

    <!-- Dialog button style -->
    <style name="Widget.A2U.Button.TextButton.Dialog" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Dialog theme for color pickers - also dark -->
    <style name="Theme_A2U_Dialog" parent="Theme.MaterialComponents.Dialog">
        <item name="a2uMidiAccent">@color/midi_accent</item>
        <item name="a2uMidiAccentOnText">@color/accent_on_text_default</item>
        <item name="a2uMusicAccent">@color/music_accent</item>
        <item name="a2uMusicAccentDim">@color/music_accent_dim</item>
        <item name="colorPrimary">@color/white</item>
        <item name="colorPrimaryVariant">@color/white</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">?attr/a2uMidiAccent</item>
        <item name="colorSecondaryVariant">?attr/a2uMidiAccent</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">#B3B3B3</item>
        <item name="android:windowBackground">@color/startup_background</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
    </style>

    <!-- NumberPicker style for dark theme -->
    <style name="NumberPickerTheme">
        <item name="android:textColorPrimary">@color/white</item>
        <item name="colorControlNormal">@color/white</item>
    </style>

    <!-- Dark AlertDialog theme with dark background -->
    <style name="Theme_A2U_AlertDialog_Dark" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">?attr/a2uMidiAccent</item>
        <item name="colorAccent">?attr/a2uMidiAccent</item>
        <item name="android:background">@color/midi_surface</item>
        <item name="android:windowBackground">@color/midi_surface</item>
        <item name="android:textColorPrimary">@color/midi_text_primary</item>
        <item name="android:textColorSecondary">@color/midi_text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.A2U.Button.TextButton.Dialog</item>
    </style>

    <!-- Practice Results Dialog - discrete centered popup -->
    <style name="Theme.PracticeResultsDialog" parent="Theme.MaterialComponents.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.5</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="a2uMidiAccent">@color/midi_accent</item>
        <item name="a2uMidiAccentOnText">@color/accent_on_text_default</item>
    </style>

    <!-- ===== Styles migrés depuis Atom2Universe ===== -->

    <!-- Dialog Theme pour les modules migrés -->
    <style name="Theme.Atom2Univers.Dialog" parent="Theme.MaterialComponents.Dialog">
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
        <item name="colorPrimary">#FFFFFF</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorSurface">#1C1C1C</item>
        <item name="colorOnSurface">#FFFFFF</item>
    </style>

    <!-- Sudoku Number Pad Button -->
    <style name="SudokuPadButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">@color/sudoku_pad_button_background</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Styles Shop (clicker) -->
    <style name="ShopStatRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
    </style>
    <style name="ShopStatLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">#94A3B8</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">monospace</item>
    </style>
    <style name="ShopStatValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#E2E8F0</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">monospace</item>
    </style>
    <style name="ShopStatDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#1E293B</item>
    </style>

    <!-- Styles Stats Clicker -->
    <style name="StatRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
    </style>
    <style name="StatLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">#AAAAAA</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">monospace</item>
    </style>
    <style name="StatValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
    </style>
    <style name="StatDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#1E1E1E</item>
    </style>

</resources>
