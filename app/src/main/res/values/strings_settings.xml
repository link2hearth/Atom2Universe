    <string name="about_description_title">About Atom²Universe</string>
    <string name="about_description">Atom²Universe is an ever-evolving all-in-one Android app built around audio, science, games and creativity, currently featuring:\n\n• Music Player — library, playlists, equalizer DSP, ID3 tag editor, Google Drive sync, Navidrome streaming\n• MIDI Player — Sonivox EAS + FluidSynth SF2 engines, falling notes, USB/Bluetooth keyboard training\n• Web Radio — internet streaming with favorites\n• Audio Editor — recording, trimming &amp; effects (FFmpeg)\n• Dictaphone — voice recorder with file manager\n• SF2 SoundFont Creator — build your own instruments\n• 26 Games — chess, sudoku, blackjack, solitaire, 2048 and many more\n• Creative Tools — pixel art editor, infinite canvas, wiki-style notes\n• Reading — EPUB &amp; PDF reader, CBZ/CBR comics viewer\n• Science — interactive periodic table (118 elements)\n• Atom Clicker — idle game with gacha collection</string>
    <string name="about_credits_title">Acknowledgments</string>
    <string name="about_credits_subtitle">A2U uses the following open source libraries:</string>
    <string name="about_credit_mididriver_name">MidiDriver</string>
    <string name="about_credit_mididriver_desc">By Bill Farmer - Android MIDI driver wrapper for Sonivox EAS. Apache 2.0 License.\nhttps://www.apache.org/licenses/LICENSE-2.0</string>
    <string name="about_credit_sonivox_name">Sonivox EAS</string>
    <string name="about_credit_sonivox_desc">By Sonic Network Inc. - Embedded Audio Synthesis engine for MIDI playback. Apache 2.0 License.</string>
    <string name="about_credit_jaudiotagger_name">JAudioTagger</string>
    <string name="about_credit_jaudiotagger_desc">By Raphaël Slinckx et al. - Java library for reading and writing audio file metadata (ID3 tags). LGPL License.\nhttps://www.gnu.org/licenses/lgpl.html</string>
    <string name="about_credit_midilib_name">android-midi-lib</string>
    <string name="about_credit_midilib_desc">By LeffelMania - MIDI file parser for Android. Apache 2.0 License.</string>
    <string name="about_credit_ffmpeg_name">FFmpeg-kit</string>
    <string name="about_credit_ffmpeg_desc">By Arthenica - FFmpeg wrapper for mobile platforms, used for audio processing. LGPL 3.0 License.</string>
    <string name="about_credit_exoplayer_name">Media3 ExoPlayer</string>
    <string name="about_credit_exoplayer_desc">By Google - Powerful media player for Android, used for music and radio playback. Apache 2.0 License.</string>
    <string name="about_credit_okhttp_name">OkHttp</string>
    <string name="about_credit_okhttp_desc">By Square - HTTP client for network requests. Apache 2.0 License.</string>
    <string name="about_credit_fluidsynth_name">FluidSynth</string>
    <string name="about_credit_fluidsynth_desc">By the FluidSynth community - Real-time software synthesizer based on the SoundFont 2 specification. LGPL 2.1 License.</string>
    <string name="about_credit_karballo_name">Karballo</string>
    <string name="about_credit_karballo_desc">By Alberto Ruibal - Chess engine for Java/Android, used for AI opponents in the chess game. MIT License.\nhttps://opensource.org/licenses/MIT</string>
    <string name="about_credit_kevinmacleod_name">Kevin MacLeod – incompetech.com</string>
    <string name="about_credit_kevinmacleod_desc">Thank you to Kevin MacLeod for sharing his music freely, making it possible to include music in this app.\nLicensed under Creative Commons: By Attribution 4.0 License\nhttp://creativecommons.org/licenses/by/4.0/</string>
    <string name="about_credit_by">Designed by Link2Hearth · Developed with Claude (Anthropic)</string>
    <string name="about_contact">contact@atom2universe.com</string>
    <string name="about_license_notice">All libraries are used in compliance with their respective licenses.\nThank you to all the open source contributors!</string>
    <string name="about_privacy_title">Privacy &amp; Permissions</string>
    <string name="about_privacy_microphone">A2U requests microphone access for two specific purposes:\n\n• Recording audio in the Audio Editor and the SoundFont Creator\n• Real-time frequency spectrum visualization in the Music Player (the app listens to the audio output to display the frequency curves)\n\nThe microphone is never used for any other purpose. No audio is recorded, transmitted, or stored without your explicit action in the Audio Editor or SoundFont Creator.</string>
