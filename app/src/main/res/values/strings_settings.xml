    <string name="permission_notification_title">Enable notifications</string>
    <string name="permission_notification_message">A2U needs notification access to display playback controls on the lock screen and status bar (radio, music).\n\nWithout it, background playback will still work but you won\'t be able to control it from outside the app.</string>
