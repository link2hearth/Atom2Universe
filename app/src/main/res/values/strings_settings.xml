    <string name="permission_dialog_message">A2U needs access to your audio files to display your music library, play your tracks, and sync your play counts.\n\nThis permission is essential for the app to work properly.</string>
    <string name="permission_dialog_grant">Grant access</string>
    <string name="permission_dialog_later">Later</string>
    <string name="permission_rationale_message">Without access to audio files, A2U cannot display your music library or play your tracks.\n\nPlease grant the permission to use the app.</string>
    <string name="permission_denied_title">Permission denied</string>
    <string name="permission_denied_message">You can grant the permission later from the app settings when you enter the Music or MIDI player.</string>
