    <string name="permission_notification_title">Aktifkan notifikasi</string>
    <string name="permission_notification_message">A2U memerlukan akses notifikasi untuk menampilkan kontrol pemutaran di layar kunci dan bilah status (radio, musik).\n\nTanpa izin ini, pemutaran latar belakang tetap berfungsi, tetapi Anda tidak dapat mengontrolnya dari luar aplikasi.</string>
    <string name="permission_dialog_title">Izin diperlukan</string>
    <string name="permission_dialog_message">A2U memerlukan akses ke file audio Anda untuk menampilkan pustaka musik, memutar lagu, dan menyinkronkan jumlah diputar.\n\nIzin ini penting agar aplikasi dapat berfungsi dengan baik.</string>
    <string name="permission_dialog_grant">Izinkan akses</string>
    <string name="permission_dialog_later">Nanti</string>
    <string name="permission_rationale_message">Tanpa akses ke file audio, A2U tidak dapat menampilkan pustaka musik atau memutar lagu Anda.\n\nMohon berikan izin untuk menggunakan aplikasi.</string>
    <string name="permission_denied_title">Izin ditolak</string>
    <string name="permission_denied_message">Anda dapat memberikan izin nanti dari pengaturan aplikasi saat membuka Pemutar Musik atau MIDI.</string>
