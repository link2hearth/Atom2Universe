    <string name="fusion_recipe_pp_name">Proton-Proton-Kette</string>
    <string name="fusion_recipe_triple_alpha_name">Dreifacher Alpha-Prozess</string>
    <string name="fusion_recipe_alpha_capture_name">Neonverbrennung</string>
