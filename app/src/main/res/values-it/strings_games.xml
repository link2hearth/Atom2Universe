    <string name="fusion_recipe_pp_name">Catena Protone-Protone</string>
    <string name="fusion_recipe_triple_alpha_name">Processo Triplo-Alfa</string>
    <string name="fusion_recipe_alpha_capture_name">Combustione del Neon</string>
