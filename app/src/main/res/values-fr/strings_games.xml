    <!-- Fusion -->
    <string name="fusion_title">FUSION</string>
    <string name="fusion_btn">⚛</string>
    <string name="fusion_recipe_pp_name">Chaîne proton-proton</string>
    <string name="fusion_recipe_triple_alpha_name">Processus triple-alpha</string>
    <string name="fusion_recipe_alpha_capture_name">Combustion du néon</string>
    <string name="fusion_recipe_carbon_fusion_name">Combustion du carbone</string>
    <string name="fusion_recipe_oxygen_fusion_name">Combustion de l\'oxygène</string>
    <string name="fusion_recipe_water_name">Synthèse du fer</string>
    <string name="fusion_recipe_pp_science">Dans les cœurs stellaires, 4 protons fusionnent par effet tunnel quantique en hélium-4, alimentant les étoiles pendant des milliards d\'années.</string>
    <string name="fusion_recipe_triple_alpha_science">Trois noyaux d\'hélium-4 se percutent via la résonance de Hoyle pour forger un noyau de carbone-12.</string>
    <string name="fusion_recipe_alpha_capture_science">Deux noyaux de néon-20 subissent une photodésintégration dans le cœur stellaire, libérant de l\'oxygène-16 et des particules alpha énergétiques.</string>
    <string name="fusion_recipe_carbon_fusion_science">Deux noyaux de carbone-12 fusionnent dans le cœur d\'une étoile massive, produisant du néon-20.</string>
    <string name="fusion_recipe_oxygen_fusion_science">Deux noyaux d\'oxygène-16 fusionnent dans le cœur d\'une étoile, produisant du soufre-32.</string>
    <string name="fusion_recipe_water_science">Par des réactions de fusion successives, les noyaux de soufre sont consumés dans le cœur d\'une étoile massive, forgeant le fer-56 — le point final de la fusion stellaire.</string>
    <string name="fusion_recipe_pp_game">4 H → He  •  75%%  •  +1%% APS ou APC</string>
    <string name="fusion_recipe_triple_alpha_game">3 He → C  •  45%%  •  +1%% APS ou APC</string>
    <string name="fusion_recipe_alpha_capture_game">2 Ne → O  •  40%%  •  +1%% APS ou APC</string>
    <string name="fusion_recipe_carbon_fusion_game">2 C → Ne  •  35%%  •  +1%% APS ou APC</string>
    <string name="fusion_recipe_oxygen_fusion_game">2 O → S  •  30%%  •  +1%% APS ou APC</string>
    <string name="fusion_recipe_water_game">2 S → Fe  •  20%%  •  +1%% APS ou APC</string>
    <string name="fusion_recipe_neutron_capture_name">Capture de neutrons</string>
    <string name="fusion_recipe_neutron_capture_science">Au-delà du fer, la fusion stellaire n\'est plus exothermique. Les éléments plus lourds se forment par capture de neutrons lors des explosions de supernova — le processus r forge cobalt, nickel, cuivre et plus encore en quelques millisecondes.</string>
    <string name="fusion_recipe_neutron_capture_game">3 Fe → élément Supernova aléatoire  •  12%%  •  +1%% APS ou APC</string>
