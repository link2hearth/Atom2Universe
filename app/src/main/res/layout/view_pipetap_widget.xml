<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#0F172A"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="#1F2937"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header draggable -->
        <FrameLayout
            android:id="@+id/pipetap_widget_header"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="start|center_vertical"
                android:paddingStart="10dp"
                android:text="⬡ PipeTap"
                android:textColor="#64748B"
                android:textSize="11sp" />

            <!-- Difficulty + moves counter -->
            <TextView
                android:id="@+id/pipetap_widget_stats"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:gravity="center"
                android:textColor="#94A3B8"
                android:textSize="10sp" />

            <!-- Reset button -->
            <TextView
                android:id="@+id/pipetap_widget_btn_new"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="↺"
                android:textColor="#64748B"
                android:textSize="14sp" />

        </FrameLayout>

        <!-- Game view + new game overlay -->
        <FrameLayout
            android:layout_width="220dp"
            android:layout_height="220dp">

            <com.Atom2Universe.app.games.pipetap.PipeTapView
                android:id="@+id/pipetap_widget_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Win overlay (GONE by default) -->
            <LinearLayout
                android:id="@+id/pipetap_win_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#CC0F172A"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textSize="36sp"
                    android:textColor="#22C55E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pipetap_solved"
                    android:textSize="16sp"
                    android:textColor="#F1F5F9"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/pipetap_win_moves"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#64748B"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- New game panel (GONE by default) -->
            <LinearLayout
                android:id="@+id/pipetap_new_game_panel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#CC0F172A"
                android:visibility="gone"
                android:padding="12dp">

                <LinearLayout
                    android:id="@+id/pipetap_new_game_diff_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/pipetap_widget_btn_cancel"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="@string/pipetap_widget_cancel"
                        android:textSize="10sp"
                        android:minWidth="0dp"
                        android:layout_marginEnd="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/pipetap_widget_btn_confirm"
                        style="?attr/materialButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="@string/pipetap_widget_confirm"
                        android:textSize="10sp"
                        android:minWidth="0dp" />

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
