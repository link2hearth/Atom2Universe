<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B2E10">

    <!-- BlackJack table view -->
    <com.Atom2Universe.app.games.blackjack.BlackjackView
        android:id="@+id/blackjack_table"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/bj_header"
        app:layout_constraintBottom_toTopOf="@id/bj_bottom_controls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Round result overlay (covers table area) -->
    <FrameLayout
        android:id="@+id/bj_result_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#AA000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/bj_header"
        app:layout_constraintBottom_toTopOf="@id/bj_bottom_controls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:id="@+id/bj_result_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="#FFD700" />

            <TextView
                android:id="@+id/bj_result_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="▶"
                android:textColor="#80FFFFFF"
                android:textSize="20sp"
                android:gravity="center" />
        </LinearLayout>
    </FrameLayout>

    <!-- Header bar -->
    <LinearLayout
        android:id="@+id/bj_header"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC000000"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/bj_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/crypto_back"
            android:tint="#FFFFFF"
            android:padding="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/blackjack_title"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/bj_ai_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#78909C"
            android:textSize="11sp"
            android:paddingEnd="10dp" />

        <TextView
            android:id="@+id/bj_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/bj_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings"
            android:tint="#94A3B8"
            android:padding="8dp" />
    </LinearLayout>

    <!-- Bottom controls container -->
    <FrameLayout
        android:id="@+id/bj_bottom_controls"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:background="#CC000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Betting bar -->
        <LinearLayout
            android:id="@+id/bj_bet_bar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/blackjack_bet_label"
                android:textColor="#94A3B8"
                android:textSize="13sp"
                android:paddingEnd="8dp" />

            <Button
                android:id="@+id/bj_bet_minus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="−"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#33FFFFFF"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp" />

            <TextView
                android:id="@+id/bj_bet_amount"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#FFD700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/bj_bet_plus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#33FFFFFF"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <Button
                android:id="@+id/bj_deal"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="@string/blackjack_deal"
                android:backgroundTint="#B71C1C"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:paddingStart="22dp"
                android:paddingEnd="22dp" />
        </LinearLayout>

        <!-- Action buttons bar (HIT / STAND / DOUBLE / SPLIT) -->
        <LinearLayout
            android:id="@+id/bj_action_bar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:visibility="gone">

            <Button
                android:id="@+id/bj_hit"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/blackjack_hit"
                android:backgroundTint="#1565C0"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/bj_stand"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/blackjack_stand"
                android:backgroundTint="#B71C1C"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/bj_double"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/blackjack_double"
                android:backgroundTint="#1B5E20"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/bj_split"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/blackjack_split"
                android:backgroundTint="#4A148C"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Waiting bar (AI/dealer turn) -->
        <LinearLayout
            android:id="@+id/bj_waiting_bar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/bj_waiting_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#78909C"
                android:textSize="14sp"
                android:textStyle="italic" />
        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
