<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/news_card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#0F172A"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:strokeColor="#1F2937"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/news_card_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="4"
            android:ellipsize="end"
            android:textColor="#F1F5F9"
            android:textSize="13sp"
            android:textStyle="bold"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:id="@+id/news_card_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#64748B"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/news_card_btn_open"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/news_open_article"
                android:textColor="#3B82F6"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_widget_arrow"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/news_card_btn_hide"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/news_hide_article"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:background="@drawable/bg_widget_arrow"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
