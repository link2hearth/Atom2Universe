<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F1E">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/circles_header"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:background="#0D1526"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/circles_back_button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/circles_back"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back_24"
            app:tint="#94A3B8" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="@string/circles_title"
            android:textColor="#E2E8F0"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Moves in header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/circles_label_moves"
            android:textColor="#64748B"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/circles_tv_moves"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="12dp"
            android:textColor="#94A3B8"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Difficulty chips -->
    <HorizontalScrollView
        android:id="@+id/circles_diff_scroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/circles_header">

        <LinearLayout
            android:id="@+id/circles_diff_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp" />

    </HorizontalScrollView>

    <!-- Bottom section (stats, hint, buttons) pinned to bottom -->
    <LinearLayout
        android:id="@+id/circles_bottom_section"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Stats row: seed + reward -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="6dp"
            android:paddingBottom="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/circles_label_seed"
                android:textColor="#64748B"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/circles_tv_seed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/circles_label_reward"
                android:textColor="#64748B"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/circles_tv_reward"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="#A78BFA"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Hint message -->
        <TextView
            android:id="@+id/circles_tv_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="#64748B"
            android:textSize="11sp"
            android:maxLines="3" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/circles_btn_new"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/circles_btn_new"
                android:textColor="#94A3B8"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/circles_btn_restart"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="@string/circles_btn_restart"
                android:textColor="#94A3B8"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/circles_btn_hint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:backgroundTint="#8B5CF6"
                android:text="@string/circles_btn_hint"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Game canvas (square, fills space between diff row and bottom section) -->
    <com.Atom2Universe.app.games.circles.CirclesView
        android:id="@+id/circles_game_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toBottomOf="@id/circles_diff_scroll"
        app:layout_constraintBottom_toTopOf="@id/circles_bottom_section"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5" />

    <!-- Win overlay -->
    <FrameLayout
        android:id="@+id/circles_win_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#CC000000"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/circles_diff_scroll"
        app:layout_constraintBottom_toTopOf="@id/circles_bottom_section"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/circles_win_title"
                android:textColor="#A78BFA"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/circles_tv_win_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="#CBD5E1"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/circles_btn_again"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:text="@string/circles_btn_again"
                    android:textColor="#94A3B8" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/circles_btn_next"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#8B5CF6"
                    android:text="@string/circles_btn_next" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
