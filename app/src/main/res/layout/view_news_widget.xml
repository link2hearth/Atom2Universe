<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/news_widget_card"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#0F172A"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="196dp"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header : label + boutons ✕ et → -->
        <FrameLayout
            android:id="@+id/news_widget_header"
            android:layout_width="match_parent"
            android:layout_height="26dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="start|center_vertical"
                android:paddingStart="8dp"
                android:gravity="center_vertical"
                android:text="@string/news_widget_label"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="end|center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/news_widget_btn_unhide"
                    android:layout_width="32dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="↩"
                    android:textColor="#10B981"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:contentDescription="@string/news_widget_btn_unhide_desc"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/news_widget_btn_hide"
                    android:layout_width="32dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="✕"
                    android:textColor="#EF4444"
                    android:textSize="12sp"
                    android:contentDescription="@string/news_widget_btn_hide_desc"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/news_widget_btn_open"
                    android:layout_width="32dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="→"
                    android:textColor="#3B82F6"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:contentDescription="@string/news_widget_btn_open_desc"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>
        </FrameLayout>

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1F2937" />

        <!-- Corps : titre + meta -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/news_widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="4"
                android:ellipsize="end"
                android:textColor="#F1F5F9"
                android:textSize="11sp"
                android:lineSpacingExtra="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/news_widget_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#64748B"
                android:textSize="10sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/news_widget_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:text="@string/news_widget_loading" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
