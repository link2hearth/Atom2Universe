<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="260dp"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/bg_popup_dark">

    <!-- Opacité -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/crypto_earth_widget_opacity_label"
            android:textColor="#94A3B8"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/popup_earth_opacity_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E2E8F0"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.slider.Slider
        android:id="@+id/popup_earth_opacity_slider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:valueFrom="0"
        android:valueTo="100"
        android:stepSize="1" />

    <!-- Séparateur -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="8dp"
        android:background="#334155" />

    <!-- Options Terre-Lune -->
    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/popup_earth_only_mode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/crypto_earth_only_mode_label"
        android:textColor="#E2E8F0"
        android:textSize="12sp" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/popup_earth_clouds"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/crypto_earth_show_clouds_label"
        android:textColor="#E2E8F0"
        android:textSize="12sp" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/popup_earth_terminator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/crypto_earth_show_terminator_label"
        android:textColor="#E2E8F0"
        android:textSize="12sp" />

</LinearLayout>
