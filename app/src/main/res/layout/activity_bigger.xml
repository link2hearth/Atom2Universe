<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0C0C14">

    <!-- Barre supérieure -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical"
        android:background="#12121E">

        <ImageButton
            android:id="@+id/bigger_btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/bigger_title"
            android:textSize="16sp"
            android:textColor="#EEEEEE"
            android:gravity="center"
            android:fontFamily="monospace"
            android:letterSpacing="0.12" />

        <TextView
            android:id="@+id/bigger_tv_goal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:textSize="11sp"
            android:textColor="#FFD700" />

        <ImageButton
            android:id="@+id/bigger_btn_restart"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/bigger_restart" />

    </LinearLayout>

    <!-- Surface de jeu -->
    <com.Atom2Universe.app.games.bigger.BiggerView
        android:id="@+id/bigger_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
