<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sudoku_widget_card"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#0F172A"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="196dp"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Zone de drag du widget (header) : ✕ · ✓ · ? · ↩ · ↪ · ↺ -->
        <LinearLayout
            android:id="@+id/sudoku_header_area"
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/sudoku_btn_cancel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="✕"
                android:textColor="#EF4444"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/sudoku_btn_validate"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="✓"
                android:textColor="#22C55E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/sudoku_btn_verify"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="?"
                android:textColor="#EAB308"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/sudoku_btn_undo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="↩"
                android:textColor="#60A5FA"
                android:textSize="14sp"
                android:textStyle="bold"
                android:alpha="0.3"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/sudoku_btn_notes"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="↪"
                android:textColor="#60A5FA"
                android:textSize="14sp"
                android:textStyle="bold"
                android:alpha="0.3"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/sudoku_btn_reset"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="↺"
                android:textColor="#F97316"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Grille 9×9 + overlay de sélection de difficulté -->
        <FrameLayout
            android:layout_width="196dp"
            android:layout_height="196dp">

        <com.Atom2Universe.app.games.sudoku.SudokuGridView
            android:id="@+id/sudoku_widget_grid"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Overlay résultat Bravo / Fail (caché par défaut) -->
        <FrameLayout
            android:id="@+id/sudoku_result_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CC0F172A"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/sudoku_result_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text=""
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#22C55E" />

        </FrameLayout>

        <!-- Overlay difficulté (caché par défaut) -->
        <FrameLayout
            android:id="@+id/sudoku_difficulty_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CC0F172A"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/sudoku_diff_easy"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="@string/sudoku_difficulty_easy"
                    android:textColor="#94A3B8"
                    android:textSize="14sp"
                    android:background="@drawable/bg_widget_arrow"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/sudoku_diff_medium"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="@string/sudoku_difficulty_medium"
                    android:textColor="#94A3B8"
                    android:textSize="14sp"
                    android:background="@drawable/bg_widget_arrow"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/sudoku_diff_hard"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="@string/sudoku_difficulty_hard"
                    android:textColor="#94A3B8"
                    android:textSize="14sp"
                    android:background="@drawable/bg_widget_arrow"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/sudoku_diff_cancel"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/sudoku_widget_cancel"
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:background="@drawable/bg_widget_arrow"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>
        </FrameLayout>

        </FrameLayout>

        <!-- Rangée de chiffres 1–9 (même style que la grille) -->
        <com.Atom2Universe.app.crypto.SudokuDigitRowView
            android:id="@+id/sudoku_digit_row"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
