<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- ── En-tête ──────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#111111"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/stats_back_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@android:color/transparent"
            android:tint="#FFFFFF"
            android:contentDescription="Retour" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/clicker_stats_title"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/stats_reset_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="@android:color/transparent"
            android:tint="#FF9999"
            android:contentDescription="@string/stats_reset_button" />

    </LinearLayout>

    <!-- ── Corps ─────────────────────────────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <!-- Clics totaux -->
            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel"
                    android:text="@string/stat_total_clicks" />
                <TextView android:id="@+id/stat_total_clicks_value"
                    style="@style/StatValue" android:text="0" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <!-- Clics pendant frénésie APC -->
            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel"
                    android:text="@string/stat_frenzy_clicks" />
                <TextView android:id="@+id/stat_frenzy_clicks_value"
                    style="@style/StatValue" android:text="0" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <!-- Frénésies APC -->
            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel"
                    android:text="@string/stat_apc_frenzies" />
                <TextView android:id="@+id/stat_apc_frenzies_value"
                    style="@style/StatValue" android:text="0" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <!-- Frénésies APS -->
            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel"
                    android:text="@string/stat_aps_frenzies" />
                <TextView android:id="@+id/stat_aps_frenzies_value"
                    style="@style/StatValue" android:text="0" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <!-- Record clics/s -->
            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel"
                    android:text="@string/stat_max_cps" />
                <TextView android:id="@+id/stat_max_cps_value"
                    style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <!-- Record clics en frénésie APC -->
            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel"
                    android:text="@string/stat_max_apc_clicks" />
                <TextView android:id="@+id/stat_max_apc_clicks_value"
                    style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <!-- Temps de jeu -->
            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel"
                    android:text="@string/stat_play_time" />
                <TextView android:id="@+id/stat_play_time_value"
                    style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <!-- Bonus éléments APC -->
            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel"
                    android:text="@string/stat_element_bonus_apc" />
                <TextView android:id="@+id/stat_element_bonus_apc_value"
                    style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <!-- Bonus éléments APS -->
            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel"
                    android:text="@string/stat_element_bonus_aps" />
                <TextView android:id="@+id/stat_element_bonus_aps_value"
                    style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <!-- Section : production totale -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/stat_production_title"
                android:textColor="#888888"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:paddingTop="12dp"
                android:paddingBottom="6dp" />

            <!-- Barre APC / APS -->
            <LinearLayout
                android:id="@+id/production_bar"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <View
                    android:id="@+id/bar_apc"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#4A90D9" />
                <View
                    android:id="@+id/bar_aps"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#4CAF50" />
            </LinearLayout>

            <!-- APC % -->
            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel"
                    android:text="@string/stat_production_apc" />
                <TextView android:id="@+id/stat_production_apc_value"
                    style="@style/StatValue" android:text="—" android:textColor="#4A90D9" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <!-- APS % -->
            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel"
                    android:text="@string/stat_production_aps" />
                <TextView android:id="@+id/stat_production_aps_value"
                    style="@style/StatValue" android:text="—" android:textColor="#4CAF50" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <!-- ── Section : victoires ────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/stat_section_wins"
                android:textColor="#888888"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:paddingTop="20dp"
                android:paddingBottom="6dp" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_solitaire_won" />
                <TextView android:id="@+id/stat_solitaire_won_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_sudoku_won" />
                <TextView android:id="@+id/stat_sudoku_won_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_chess_won" />
                <TextView android:id="@+id/stat_chess_won_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_draughts_won" />
                <TextView android:id="@+id/stat_draughts_won_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_2048_won" />
                <TextView android:id="@+id/stat_2048_won_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_blackjack_won" />
                <TextView android:id="@+id/stat_blackjack_won_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_colorstack_won" />
                <TextView android:id="@+id/stat_colorstack_won_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_colorstack_best_time" />
                <TextView android:id="@+id/stat_colorstack_time_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_pipetap_won" />
                <TextView android:id="@+id/stat_pipetap_won_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>

            <!-- ── Section : records ─────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/stat_section_records"
                android:textColor="#888888"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:paddingTop="20dp"
                android:paddingBottom="6dp" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_starswar_score" />
                <TextView android:id="@+id/stat_starswar_score_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_starswar_wave" />
                <TextView android:id="@+id/stat_starswar_wave_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_reflex_easy" />
                <TextView android:id="@+id/stat_reflex_easy_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_reflex_hard" />
                <TextView android:id="@+id/stat_reflex_hard_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_flappy_score" />
                <TextView android:id="@+id/stat_flappy_score_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_2048_best" />
                <TextView android:id="@+id/stat_2048_best_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_particules_score" />
                <TextView android:id="@+id/stat_particules_score_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_particules_level" />
                <TextView android:id="@+id/stat_particules_level_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_wavesurf_speed" />
                <TextView android:id="@+id/stat_wavesurf_speed_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_wavesurf_altitude" />
                <TextView android:id="@+id/stat_wavesurf_altitude_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_survivor_time" />
                <TextView android:id="@+id/stat_survivor_time_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>
            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatRow">
                <TextView style="@style/StatLabel" android:text="@string/stat_survivor_level" />
                <TextView android:id="@+id/stat_survivor_kills_value" style="@style/StatValue" android:text="—" />
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
