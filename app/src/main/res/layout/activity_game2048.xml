<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/startup_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/game2048_title"
            android:textSize="22sp"
            android:textColor="@color/startup_text_primary"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Score panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/game2048_score_label"
                android:textColor="@color/startup_text_secondary"
                android:textSize="11sp" />
            <TextView
                android:id="@+id/game2048_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/startup_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/game2048_best_label"
                android:textColor="@color/startup_text_secondary"
                android:textSize="11sp" />
            <TextView
                android:id="@+id/game2048_best"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#EDC22E"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/game2048_universes_label"
                android:textColor="@color/startup_text_secondary"
                android:textSize="11sp" />
            <TextView
                android:id="@+id/game2048_universes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#7E57C2"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Controls: taille + cible + nouvelle partie -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/game2048_size_label"
            android:textColor="@color/startup_text_secondary"
            android:textSize="12sp"
            android:layout_marginEnd="4dp" />

        <Spinner
            android:id="@+id/game2048_size_spinner"
            android:layout_width="72dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/game2048_target_label"
            android:textColor="@color/startup_text_secondary"
            android:textSize="12sp"
            android:layout_marginEnd="4dp" />

        <Spinner
            android:id="@+id/game2048_target_spinner"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/game2048_new_button"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/game2048_new"
            android:textSize="12sp"
            android:backgroundTint="#607D8B" />
    </LinearLayout>

    <!-- Ligne Mode Quantique 🐱 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/game2048_quantum_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/game2048_quantum_mode"
            android:textColor="#A78BFA"
            android:textSize="13sp"
            android:layout_marginEnd="12dp" />

        <!-- Bouton joker (visible seulement en mode quantique) -->
        <Button
            android:id="@+id/game2048_joker_button"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="🐱 ×0"
            android:textSize="13sp"
            android:backgroundTint="#1E293B"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Status -->
    <TextView
        android:id="@+id/game2048_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp"
        android:gravity="center"
        android:textColor="@color/startup_text_secondary"
        android:textSize="13sp"
        android:text="@string/game2048_status_play" />

    <!-- Board -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp">

        <com.Atom2Universe.app.games.game2048.Game2048View
            android:id="@+id/game2048_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />
    </FrameLayout>

</LinearLayout>
