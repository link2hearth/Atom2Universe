<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground"
    android:padding="16dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="2dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/cave_world_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/midi_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/cave_world_seed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/midi_text_secondary"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/cave_world_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/midi_text_secondary"
            android:textSize="11sp"
            android:alpha="0.6" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/cave_world_delete"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@android:color/transparent"
        android:src="@android:drawable/ic_menu_delete"
        android:tint="@color/midi_text_secondary"
        android:contentDescription="@string/cave_menu_delete_world" />

</LinearLayout>
