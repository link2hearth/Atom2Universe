<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#0F172A"
    app:cardCornerRadius="18dp"
    app:cardElevation="8dp"
    app:strokeColor="#1F2937"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header : compteur de pièces + bouton reset -->
        <FrameLayout
            android:id="@+id/draughts_header_area"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/draughts_piece_count"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginEnd="28dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:textSize="11sp"
                android:textColor="#94A3B8"
                android:singleLine="true" />

            <TextView
                android:id="@+id/draughts_btn_reset"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:gravity="center"
                android:text="@string/draughts_widget_reset_btn"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

        </FrameLayout>

        <!-- Damier 10×10 + overlays -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="200dp">

            <com.Atom2Universe.app.games.draughts.DraughtsView
                android:id="@+id/draughts_widget_board"
                android:layout_width="184dp"
                android:layout_height="184dp"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- Overlay résultat (caché par défaut) -->
            <FrameLayout
                android:id="@+id/draughts_result_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#CC0F172A"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/draughts_result_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text=""
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="#22C55E" />

            </FrameLayout>

            <!-- Overlay sélection de difficulté (caché par défaut) -->
            <FrameLayout
                android:id="@+id/draughts_difficulty_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#CC0F172A"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:id="@+id/draughts_diff_training"
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:text="@string/draughts_difficulty_training"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:background="@drawable/bg_widget_arrow"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/draughts_diff_standard"
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="@string/draughts_difficulty_standard"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:background="@drawable/bg_widget_arrow"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/draughts_diff_expert"
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="@string/draughts_difficulty_expert"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:background="@drawable/bg_widget_arrow"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/draughts_diff_two_player"
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="@string/draughts_difficulty_two_player"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:background="@drawable/bg_widget_arrow"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/draughts_diff_cancel"
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="@string/draughts_widget_cancel"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:background="@drawable/bg_widget_arrow"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </FrameLayout>

        </FrameLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
