<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#010310">

    <!-- Header -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/big_bang_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start|center_vertical"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@android:color/transparent"
            app:tint="#AAFFFFFF"
            android:contentDescription="@string/back" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/big_bang_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/big_bang_title"
                android:textColor="#FFD700"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.2" />
        </LinearLayout>

        <TextView
            android:id="@+id/big_bang_token_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:textColor="#AAFFFFFF"
            android:textSize="13sp" />
    </FrameLayout>

    <!-- Description -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/big_bang_description"
        android:textColor="#88FFFFFF"
        android:textSize="12sp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp" />

    <!-- Liste des bonus -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/big_bang_bonus_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp" />
    </ScrollView>

    <!-- Bas : résumé + bouton Big Bang -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1AFFFFFF"
        android:padding="12dp">

        <TextView
            android:id="@+id/big_bang_pending_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFD700"
            android:textSize="13sp"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/big_bang_reset_warning"
            android:textColor="#88FF6666"
            android:textSize="11sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/big_bang_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/big_bang_button"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#CC880000"
            android:textColor="#FFFFFFFF" />
    </LinearLayout>
</LinearLayout>
