<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/book_reader_title" />

    <FrameLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- État vide -->
        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_hub_books"
                android:alpha="0.3"
                android:layout_marginBottom="20dp"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/book_reader_no_book"
                android:textSize="16sp"
                android:alpha="0.6"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/open_book_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/book_reader_open" />
        </LinearLayout>

        <!-- Visionneuse PDF -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/pdf_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- Visionneuse TXT -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/txt_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Séparateur -->
    <View
        android:id="@+id/bottom_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:visibility="gone" />

    <!-- Barre inférieure : TTS + compteur -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:visibility="gone">

        <!-- Play / Pause -->
        <TextView
            android:id="@+id/tts_play_pause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="▶"
            android:textSize="22sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <!-- Vitesse -->
        <TextView
            android:id="@+id/tts_speed_btn"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="1.0×"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <!-- Ton -->
        <TextView
            android:id="@+id/tts_pitch_btn"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="1.0♪"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <!-- Voix -->
        <TextView
            android:id="@+id/tts_voice_btn"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="VOX"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Compteur de position -->
        <TextView
            android:id="@+id/page_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

    </LinearLayout>

</LinearLayout>
