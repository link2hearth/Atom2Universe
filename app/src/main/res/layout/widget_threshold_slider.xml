<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_dialog_bg"
    android:padding="16dp"
    android:elevation="8dp">

    <!-- Barre de titre draggable -->
    <LinearLayout
        android:id="@+id/drag_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_drag_handle"
            android:contentDescription="@string/canvas_threshold_drag" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/canvas_threshold_title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

    </LinearLayout>

    <!-- Valeur actuelle -->
    <TextView
        android:id="@+id/threshold_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="250"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <!-- Slider -->
    <SeekBar
        android:id="@+id/threshold_slider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:min="200"
        android:max="255"
        android:progress="250" />

    <!-- Labels min/max -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="200"
            android:textSize="12sp"
            android:alpha="0.7" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="255"
            android:textSize="12sp"
            android:alpha="0.7"
            android:gravity="end" />

    </LinearLayout>

    <!-- Description -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/canvas_threshold_description"
        android:textSize="12sp"
        android:alpha="0.7"
        android:paddingTop="12dp"
        android:paddingBottom="12dp" />

    <!-- Bouton valider -->
    <Button
        android:id="@+id/btn_validate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/canvas_threshold_validate" />

</LinearLayout>
