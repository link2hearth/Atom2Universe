<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/startup_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:gravity="center_vertical"
        android:background="@color/startup_background">

        <ImageButton
            android:id="@+id/wave_surf_btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="?attr/a2uMidiAccent"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/back" />

        <TextView
            android:id="@+id/wave_surf_hud_distance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 m"
            android:textSize="15sp"
            android:textColor="?attr/a2uMidiAccent"
            android:gravity="center"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/wave_surf_hud_speed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 km/h"
            android:textSize="14sp"
            android:textColor="?attr/a2uMidiAccent"
            android:gravity="center"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/wave_surf_hud_altitude"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 m ↑"
            android:textSize="14sp"
            android:textColor="?attr/a2uMidiAccent"
            android:gravity="center"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/wave_surf_btn_theme"
            android:layout_width="52dp"
            android:layout_height="36dp"
            android:text="@string/wave_surf_theme_vivid"
            android:textSize="10sp"
            android:gravity="center"
            android:textColor="?attr/a2uMidiAccent"
            android:background="?selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <ImageButton
            android:id="@+id/wave_surf_btn_restart"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_refresh"
            android:tint="?attr/a2uMidiAccent"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/wave_surf_restart" />

    </LinearLayout>

    <com.Atom2Universe.app.games.wavesurf.WaveSurfView
        android:id="@+id/wave_surf_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
