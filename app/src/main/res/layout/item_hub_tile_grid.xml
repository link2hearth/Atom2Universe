<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/tile_card"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Quick access container : moitié gauche, 3 boutons empilés verticalement -->
        <LinearLayout
            android:id="@+id/tile_quick_access_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintWidth_percent="0.5"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tile_quick_access_1"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/quick_access_badge_bg"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:paddingHorizontal="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tile_quick_access_2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="2dp"
                android:background="@drawable/quick_access_badge_bg"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:paddingHorizontal="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tile_quick_access_3"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="2dp"
                android:background="@drawable/quick_access_badge_bg"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:paddingHorizontal="6dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Edit button (visible en mode édition) -->
        <ImageButton
            android:id="@+id/tile_edit_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_margin="8dp"
            android:background="@drawable/circle_button_bg"
            android:contentDescription="@string/hub_edit_tile"
            android:src="@drawable/ic_edit"
            android:visibility="gone"
            app:tint="@android:color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Icon -->
        <ImageView
            android:id="@+id/tile_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:importantForAccessibility="no"
            app:tint="@android:color/white"
            app:layout_constraintBottom_toTopOf="@id/tile_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tile_quick_access_container"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <!-- Title -->
        <TextView
            android:id="@+id/tile_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintBottom_toTopOf="@id/tile_description"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tile_quick_access_container"
            app:layout_constraintTop_toBottomOf="@id/tile_icon" />

        <!-- Description -->
        <TextView
            android:id="@+id/tile_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:alpha="0.8"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tile_quick_access_container"
            app:layout_constraintTop_toBottomOf="@id/tile_title" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
