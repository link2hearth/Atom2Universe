<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:ignore="TooManyViews">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ==================== Header: Name & Export ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sf2_instrument_name_label"
                    android:textColor="@color/startup_text_secondary"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/instrument_name_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:autofillHints=""
                    android:background="@drawable/bg_rounded_dark"
                    android:hint="@string/sf2_instrument_name_hint"
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:maxLength="20"
                    android:padding="10dp"
                    android:textColor="@color/startup_text_primary"
                    android:textColorHint="@color/startup_text_secondary"
                    android:textSize="14sp" />

            </LinearLayout>

            <Button
                android:id="@+id/export_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="?attr/a2uMidiAccent"
                android:text="@string/sf2_export"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:minWidth="90dp" />

        </LinearLayout>

        <!-- MIDI Program selector -->
        <TextView
            android:id="@+id/program_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/sf2_program_label"
            android:textColor="@color/startup_text_secondary"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/program_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_rounded_dark"
            android:padding="8dp"
            android:popupBackground="@color/startup_background" />

        <!-- Root note & Key Range -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sf2_root_note_title"
                    android:textColor="@color/startup_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/root_note_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/a2uMidiAccent"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <Button
                android:id="@+id/change_note_button"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:backgroundTint="@color/startup_button_background"
                android:text="@string/sf2_change_note"
                android:textColor="@color/startup_text_primary"
                android:textSize="11sp"
                android:minWidth="0dp"
                android:paddingHorizontal="12dp" />

        </LinearLayout>

        <!-- Key Range (shown in edit mode) -->
        <LinearLayout
            android:id="@+id/key_range_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sf2_key_range"
                android:textColor="@color/startup_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/key_range_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:textColor="?attr/a2uMidiAccent"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/set_key_range_button"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:backgroundTint="@color/startup_button_background"
                android:text="@string/sf2_set_key_range"
                android:textColor="@color/startup_text_primary"
                android:textSize="11sp"
                android:minWidth="0dp"
                android:paddingHorizontal="12dp" />

        </LinearLayout>

        <!-- Velocity Range (shown in edit mode) -->
        <LinearLayout
            android:id="@+id/vel_range_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sf2_section_velocity"
                android:textColor="@color/startup_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/vel_range_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:textColor="?attr/a2uMidiAccent"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/set_vel_range_button"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:backgroundTint="@color/startup_button_background"
                android:text="@string/sf2_change_note"
                android:textColor="@color/startup_text_primary"
                android:textSize="11sp"
                android:minWidth="0dp"
                android:paddingHorizontal="12dp" />

        </LinearLayout>

        <!-- ==================== Keyboard Preview ==================== -->
        <TextView
            android:id="@+id/preview_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/sf2_preview_label"
            android:textColor="@color/startup_text_secondary"
            android:textSize="12sp" />

        <!-- Engine selector row -->
        <LinearLayout
            android:id="@+id/engine_selector_row"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/engine_name_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/startup_text_secondary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/switch_engine_button"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="12dp"
                android:text="@string/sf2_preview_engine_switch"
                android:textColor="?attr/a2uMidiAccent"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/keyboard_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/octave_down_button"
                android:layout_width="36dp"
                android:layout_height="100dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/sf2_octave_down"
                android:src="@drawable/ic_chevron_left"
                app:tint="@color/startup_text_secondary" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <com.Atom2Universe.app.sf2creator.ui.KeyboardPreviewView
                    android:id="@+id/keyboard_preview"
                    android:layout_width="match_parent"
                    android:layout_height="100dp" />

                <ProgressBar
                    android:id="@+id/keyboard_loading_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminateTint="?attr/a2uMidiAccent" />

            </FrameLayout>

            <ImageButton
                android:id="@+id/octave_up_button"
                android:layout_width="36dp"
                android:layout_height="100dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/sf2_octave_up"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/startup_text_secondary" />

        </LinearLayout>

        <!-- ==================== Slider Controls (shown when slider selected) ==================== -->
        <LinearLayout
            android:id="@+id/slider_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone"
            android:padding="6dp"
            android:background="@drawable/bg_rounded_dark">

            <Button
                android:id="@+id/ctrl_minus_large"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="44dp"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:padding="0dp"
                android:text="@string/sf2_ctrl_minus_large"
                android:textColor="?attr/a2uMidiAccent"
                android:textSize="14sp"
                app:strokeColor="?attr/a2uMidiAccent" />

            <Button
                android:id="@+id/ctrl_minus_small"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="44dp"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:padding="0dp"
                android:text="@string/sf2_ctrl_minus_small"
                android:textColor="?attr/a2uMidiAccent"
                android:textSize="14sp"
                app:strokeColor="?attr/a2uMidiAccent" />

            <Button
                android:id="@+id/ctrl_reset"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:padding="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="@string/sf2_ctrl_reset"
                android:textColor="@color/startup_text_secondary"
                android:textSize="12sp"
                app:strokeColor="@color/startup_text_secondary" />

            <Button
                android:id="@+id/ctrl_plus_small"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="44dp"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:padding="0dp"
                android:text="@string/sf2_ctrl_plus_small"
                android:textColor="?attr/a2uMidiAccent"
                android:textSize="14sp"
                app:strokeColor="?attr/a2uMidiAccent" />

            <Button
                android:id="@+id/ctrl_plus_large"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="44dp"
                android:layout_height="36dp"
                android:padding="0dp"
                android:text="@string/sf2_ctrl_plus_large"
                android:textColor="?attr/a2uMidiAccent"
                android:textSize="14sp"
                app:strokeColor="?attr/a2uMidiAccent" />

        </LinearLayout>

        <TextView
            android:id="@+id/selected_slider_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="?attr/a2uMidiAccent"
            android:textSize="11sp"
            android:visibility="gone" />

        <!-- ==================== TUNING & GAIN SECTION ==================== -->
        <com.Atom2Universe.app.sf2creator.ui.components.ExpandableSectionView
            android:id="@+id/section_tuning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:sectionTitle="@string/sf2_section_tuning"
            app:showResetButton="true"
            app:startExpanded="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include android:id="@+id/gain_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/coarse_tune_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/fine_tune_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/scale_tune_row" layout="@layout/item_parameter_slider" />

            </LinearLayout>

        </com.Atom2Universe.app.sf2creator.ui.components.ExpandableSectionView>

        <!-- ==================== VOLUME ENVELOPE SECTION ==================== -->
        <com.Atom2Universe.app.sf2creator.ui.components.ExpandableSectionView
            android:id="@+id/section_vol_env"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:sectionTitle="@string/sf2_section_vol_envelope"
            app:showResetButton="true"
            app:startExpanded="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include android:id="@+id/vol_env_delay_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/vol_env_attack_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/vol_env_hold_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/vol_env_decay_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/vol_env_sustain_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/vol_env_release_row" layout="@layout/item_parameter_slider" />

            </LinearLayout>

        </com.Atom2Universe.app.sf2creator.ui.components.ExpandableSectionView>

        <!-- ==================== MODULATION ENVELOPE SECTION ==================== -->
        <com.Atom2Universe.app.sf2creator.ui.components.ExpandableSectionView
            android:id="@+id/section_mod_env"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:sectionTitle="@string/sf2_section_mod_envelope"
            app:showResetButton="true"
            app:startExpanded="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include android:id="@+id/mod_env_delay_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/mod_env_attack_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/mod_env_hold_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/mod_env_decay_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/mod_env_sustain_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/mod_env_release_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/mod_env_to_pitch_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/mod_env_to_filter_row" layout="@layout/item_parameter_slider" />

            </LinearLayout>

        </com.Atom2Universe.app.sf2creator.ui.components.ExpandableSectionView>

        <!-- ==================== VIBRATO LFO SECTION ==================== -->
        <com.Atom2Universe.app.sf2creator.ui.components.ExpandableSectionView
            android:id="@+id/section_vib_lfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:sectionTitle="@string/sf2_section_vib_lfo"
            app:showResetButton="true"
            app:startExpanded="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include android:id="@+id/vib_lfo_delay_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/vib_lfo_freq_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/vib_lfo_to_pitch_row" layout="@layout/item_parameter_slider" />

            </LinearLayout>

        </com.Atom2Universe.app.sf2creator.ui.components.ExpandableSectionView>

        <!-- ==================== MODULATION LFO SECTION ==================== -->
        <com.Atom2Universe.app.sf2creator.ui.components.ExpandableSectionView
            android:id="@+id/section_mod_lfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:sectionTitle="@string/sf2_section_mod_lfo"
            app:showResetButton="true"
            app:startExpanded="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include android:id="@+id/mod_lfo_delay_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/mod_lfo_freq_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/mod_lfo_to_pitch_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/mod_lfo_to_filter_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/mod_lfo_to_vol_row" layout="@layout/item_parameter_slider" />

            </LinearLayout>

        </com.Atom2Universe.app.sf2creator.ui.components.ExpandableSectionView>

        <!-- ==================== FILTER SECTION ==================== -->
        <com.Atom2Universe.app.sf2creator.ui.components.ExpandableSectionView
            android:id="@+id/section_filter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:sectionTitle="@string/sf2_section_filter"
            app:showResetButton="true"
            app:startExpanded="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include android:id="@+id/filter_cutoff_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/filter_resonance_row" layout="@layout/item_parameter_slider" />

            </LinearLayout>

        </com.Atom2Universe.app.sf2creator.ui.components.ExpandableSectionView>

        <!-- ==================== EFFECTS SECTION ==================== -->
        <com.Atom2Universe.app.sf2creator.ui.components.ExpandableSectionView
            android:id="@+id/section_effects"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:sectionTitle="@string/sf2_section_effects"
            app:showResetButton="true"
            app:startExpanded="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include android:id="@+id/chorus_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/reverb_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/pan_row" layout="@layout/item_parameter_slider" />
                <include android:id="@+id/exclusive_class_row" layout="@layout/item_parameter_slider" />

            </LinearLayout>

        </com.Atom2Universe.app.sf2creator.ui.components.ExpandableSectionView>

        <!-- ==================== Status & Progress ==================== -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:indeterminateTint="?attr/a2uMidiAccent" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/startup_text_secondary"
            android:textSize="12sp" />

        <!-- Post-export buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal"
            style="?android:attr/buttonBarStyle">

            <Button
                android:id="@+id/share_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/startup_button_background"
                android:drawableStart="@drawable/ic_share"
                android:drawablePadding="8dp"
                android:drawableTint="@color/startup_text_primary"
                android:text="@string/sf2_share"
                android:textColor="@color/startup_text_primary"
                android:visibility="gone"
                style="?android:attr/buttonBarButtonStyle" />

            <Button
                android:id="@+id/open_midi_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:backgroundTint="@color/startup_button_background"
                android:drawableStart="@drawable/ic_midi"
                android:drawablePadding="8dp"
                android:drawableTint="@color/startup_text_primary"
                android:text="@string/sf2_open_midi"
                android:textColor="@color/startup_text_primary"
                android:visibility="gone"
                style="?android:attr/buttonBarButtonStyle" />

        </LinearLayout>

        <!-- Add to Project / Save button -->
        <Button
            android:id="@+id/add_to_project_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/startup_button_background"
            android:drawableStart="@drawable/ic_folder_open"
            android:drawablePadding="8dp"
            android:drawableTint="?attr/a2uMidiAccent"
            android:text="@string/sf2_add_to_project"
            android:textColor="@color/startup_text_primary" />

    </LinearLayout>

</ScrollView>
