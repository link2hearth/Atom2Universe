<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- Zone supérieure : Pochette avec artiste en overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Album Art -->
        <ImageView
            android:id="@+id/widget_album_art"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_music_note"
            android:contentDescription="@string/widget_album_art" />

        <!-- Overlay artiste en bas de la pochette -->
        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#AA000000"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:paddingHorizontal="6dp"
            android:paddingVertical="4dp"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

        <!-- Source Badge (Music/Radio/MIDI) en haut à droite -->
        <TextView
            android:id="@+id/widget_source_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="2dp"
            android:background="@drawable/widget_source_badge_bg"
            android:paddingLeft="6dp"
            android:paddingTop="2dp"
            android:paddingRight="6dp"
            android:paddingBottom="2dp"
            android:text="RADIO"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Titre (grand, entre pochette et boutons) -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:paddingHorizontal="4dp"
        android:paddingVertical="6dp"
        android:text="@string/widget_no_track"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Contrôles (compacts) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Previous Button -->
        <ImageButton
            android:id="@+id/widget_btn_prev"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="@string/widget_previous"
            android:scaleType="centerInside"
            android:src="@drawable/ic_skip_previous" />

        <!-- Play/Pause Button -->
        <ImageButton
            android:id="@+id/widget_btn_play_pause"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="@string/widget_play_pause"
            android:scaleType="centerInside"
            android:src="@drawable/ic_play" />

        <!-- Next Button -->
        <ImageButton
            android:id="@+id/widget_btn_next"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="@string/widget_next"
            android:scaleType="centerInside"
            android:src="@drawable/ic_skip_next" />

    </LinearLayout>

</LinearLayout>
