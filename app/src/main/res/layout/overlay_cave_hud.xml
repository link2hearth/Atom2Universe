<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Zone principale (tout sauf hotbar) -->
    <FrameLayout
        android:id="@+id/cave_game_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Back -->
        <ImageButton
            android:id="@+id/cave_btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|start"
            android:layout_margin="8dp"
            android:background="#55000000"
            android:contentDescription="@string/cave_back"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#FFFFFF" />

        <!-- Coordonnées (haut centre) -->
        <TextView
            android:id="@+id/cave_tv_coords"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="12dp"
            android:fontFamily="monospace"
            android:text="0.0  0.0  0.0"
            android:textColor="#99FFFFFF"
            android:textSize="11sp" />

        <!-- Boutons contrôle (haut droit) : mode + jour/nuit -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/cave_btn_day_night"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:background="#55000000"
                android:text="🌙"
                android:textSize="14sp" />

            <Button
                android:id="@+id/cave_btn_mode"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="#55000000"
                android:paddingHorizontal="12dp"
                android:text="@string/cave_mode_spectator"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Crosshair centre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="monospace"
            android:text="+"
            android:textColor="#CCFFFFFF"
            android:textSize="22sp" />

        <!-- Barre de progression minage (centre bas) -->
        <LinearLayout
            android:id="@+id/cave_mining_panel"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/cave_tv_mining_block"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:textColor="#FFFFFFFF"
                android:textSize="11sp" />

            <ProgressBar
                android:id="@+id/cave_mining_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#00D4FF" />
        </LinearLayout>

        <!-- JUMP / FLY UP — position appliquée par CaveActivity via CaveControlsPrefs -->
        <Button
            android:id="@+id/cave_btn_up"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="top|start"
            android:text="▲"
            android:textColor="#FFFFFF"
            android:textSize="22sp" />

        <!-- FLY DOWN (spectateur seulement) -->
        <Button
            android:id="@+id/cave_btn_down"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="top|start"
            android:visibility="gone"
            android:text="▼"
            android:textColor="#FFFFFF"
            android:textSize="22sp" />

        <!-- LASER -->
        <Button
            android:id="@+id/cave_btn_laser"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="top|start"
            android:text="@string/cave_laser"
            android:textColor="#00D4FF"
            android:textSize="10sp" />

        <!-- PLACE -->
        <Button
            android:id="@+id/cave_btn_place"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="top|start"
            android:text="@string/cave_place"
            android:textColor="#88FF44"
            android:textSize="10sp" />

        <!-- Hint gauche -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="8dp"
            android:text="@string/cave_hint_move"
            android:textColor="#44FFFFFF"
            android:textSize="10sp" />

    </FrameLayout>

    <!-- Hotbar (bas, 60dp) -->
    <LinearLayout
        android:id="@+id/cave_hotbar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#BB000000"
        android:orientation="horizontal"
        android:padding="4dp" />

</LinearLayout>
