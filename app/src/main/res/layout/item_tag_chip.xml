<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="3dp"
    app:cardBackgroundColor="#1E293B"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#334155"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/tag_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#F1F5F9"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tag_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="#64748B"
            android:textSize="10sp" />

        <ImageView
            android:id="@+id/tag_expand_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="2dp"
            android:src="@drawable/ic_expand_more_24"
            app:tint="#64748B"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/tag_edit_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="2dp"
            android:src="@drawable/ic_edit_24"
            app:tint="#64748B"
            android:contentDescription="@string/notes_edit_tag"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
