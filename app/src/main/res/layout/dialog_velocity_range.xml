<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sf2_vel_range_title"
        android:textColor="@color/startup_text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/sf2_vel_range_hint"
        android:textColor="@color/startup_text_secondary"
        android:textSize="12sp" />

    <!-- Start Velocity -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/sf2_vel_start_label"
        android:textColor="@color/startup_text_secondary"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <SeekBar
            android:id="@+id/vel_start_seekbar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="127"
            android:progressTint="?attr/a2uMidiAccent"
            android:thumbTint="?attr/a2uMidiAccent" />

        <TextView
            android:id="@+id/vel_start_value"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="@color/startup_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- End Velocity -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/sf2_vel_end_label"
        android:textColor="@color/startup_text_secondary"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <SeekBar
            android:id="@+id/vel_end_seekbar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="127"
            android:progressTint="?attr/a2uMidiAccent"
            android:thumbTint="?attr/a2uMidiAccent" />

        <TextView
            android:id="@+id/vel_end_value"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="@color/startup_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Preview -->
    <TextView
        android:id="@+id/vel_preview_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textColor="?attr/a2uMidiAccent"
        android:textSize="14sp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="end"
        android:orientation="horizontal"
        style="?android:attr/buttonBarStyle">

        <Button
            android:id="@+id/cancel_button"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:minWidth="100dp"
            android:background="@drawable/bg_rounded_dark"
            android:text="@string/midi_cancel"
            android:textColor="@color/startup_text_secondary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/ok_button"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:minWidth="100dp"
            android:backgroundTint="?attr/a2uMidiAccent"
            android:text="@string/sf2_confirm"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>
