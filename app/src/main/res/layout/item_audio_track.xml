<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <!-- Drag handle -->
    <ImageView
        android:id="@+id/dragHandle"
        android:layout_width="32dp"
        android:layout_height="match_parent"
        android:src="@drawable/ic_drag_handle"
        android:scaleType="center"
        android:contentDescription="@string/audio_editor_drag_reorder"
        android:paddingVertical="16dp" />

    <!-- Track container -->
    <LinearLayout
        android:id="@+id/trackContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/track_background_inactive"
        android:padding="8dp">

        <!-- Track header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <!-- Track number indicator -->
            <TextView
                android:id="@+id/tvTrackNumber"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                tools:text="1"
                android:textStyle="bold"
                android:background="@drawable/circle_button_bg"
                android:layout_marginEnd="6dp" />

            <!-- Track name -->
            <TextView
                android:id="@+id/tvTrackName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF"
                tools:text="Track 1"
                android:textSize="12sp"
                android:ellipsize="end"
                android:singleLine="true" />

            <!-- Track duration -->
            <TextView
                android:id="@+id/tvTrackDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                tools:text="00:00"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginEnd="8dp" />

            <!-- Remove track button -->
            <ImageButton
                android:id="@+id/btnRemoveTrack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/audio_editor_remove_track"
                android:src="@drawable/ic_close"
                android:padding="4dp"
                app:tint="#888888" />

        </LinearLayout>

        <!-- Waveform view -->
        <com.Atom2Universe.app.audioeditor.WaveformView
            android:id="@+id/trackWaveformView"
            android:layout_width="match_parent"
            android:layout_height="60dp" />

        <com.Atom2Universe.app.audioeditor.SpectrumView
            android:id="@+id/trackSpectrumView"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
