<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="4dp"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:background="?attr/selectableItemBackground">

    <!-- Drag handle -->
    <ImageView
        android:id="@+id/drag_handle"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_sort_by_size"
        android:alpha="0.5"
        android:contentDescription="@string/music_drag_to_reorder"
        app:tint="@color/music_text_secondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Track number in queue -->
    <TextView
        android:id="@+id/queue_position"
        android:layout_width="24dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:textSize="12sp"
        android:textColor="@color/music_text_secondary"
        android:gravity="center"
        tools:text="01"
        app:layout_constraintStart_toEndOf="@id/drag_handle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/track_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="4dp"
        android:textSize="13sp"
        android:textColor="@color/music_text_primary"
        android:maxLines="1"
        android:ellipsize="end"
        tools:text="Track Title"
        app:layout_constraintStart_toEndOf="@id/queue_position"
        app:layout_constraintEnd_toStartOf="@id/track_play_count"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/track_artist" />

    <TextView
        android:id="@+id/track_artist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="4dp"
        android:textSize="11sp"
        android:textColor="@color/music_text_secondary"
        android:maxLines="1"
        android:ellipsize="end"
        tools:text="Artist Name"
        app:layout_constraintStart_toEndOf="@id/queue_position"
        app:layout_constraintEnd_toStartOf="@id/track_play_count"
        app:layout_constraintTop_toBottomOf="@id/track_title"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Play count -->
    <TextView
        android:id="@+id/track_play_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="@color/music_text_secondary"
        android:visibility="gone"
        tools:text="12x"
        app:layout_constraintEnd_toStartOf="@id/btn_favorite"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Favorite button -->
    <ImageButton
        android:id="@+id/btn_favorite"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="2dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_favorite_outline"
        android:scaleType="centerInside"
        app:tint="@color/music_text_secondary"
        android:contentDescription="@string/music_add_to_favorites"
        app:layout_constraintEnd_toStartOf="@id/track_duration"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/track_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:textSize="11sp"
        android:textColor="@color/music_text_secondary"
        tools:text="3:45"
        app:layout_constraintEnd_toStartOf="@id/playing_indicator"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Playing indicator on the right -->
    <ImageView
        android:id="@+id/playing_indicator"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="4dp"
        android:src="@android:drawable/ic_media_play"
        android:visibility="invisible"
        android:contentDescription="@string/music_now_playing"
        app:tint="?attr/a2uMusicAccent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
