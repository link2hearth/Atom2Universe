<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable slider row for SF2 parameters -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="40dp"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/param_label"
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/startup_text_secondary"
        android:textSize="11sp" />

    <SeekBar
        android:id="@+id/param_seekbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:progressTint="?attr/a2uMidiAccent"
        android:thumbTint="?attr/a2uMidiAccent" />

    <TextView
        android:id="@+id/param_value"
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="@color/startup_text_primary"
        android:textSize="11sp" />

</LinearLayout>
