<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/startup_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:gravity="center_vertical"
        android:background="@color/startup_background">

        <ImageButton
            android:id="@+id/motocross_btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="?attr/a2uMidiAccent"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/back" />

        <TextView
            android:id="@+id/motocross_hud_distance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 m"
            android:textSize="15sp"
            android:textColor="?attr/a2uMidiAccent"
            android:gravity="center"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/motocross_hud_speed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 km/h"
            android:textSize="15sp"
            android:textColor="?attr/a2uMidiAccent"
            android:gravity="center"
            android:fontFamily="monospace" />

        <ImageButton
            android:id="@+id/motocross_btn_restart"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_refresh"
            app:tint="?attr/a2uMidiAccent"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/motocross_restart" />

    </LinearLayout>

    <com.Atom2Universe.app.games.motocross.MotocrossView
        android:id="@+id/motocross_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
