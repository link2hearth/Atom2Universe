<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/the_line_widget_card"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#0F172A"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="#1F2937"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header draggable : label difficulté + bouton reset -->
        <FrameLayout
            android:id="@+id/the_line_widget_header_area"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/the_line_widget_difficulty"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="@string/the_line_diff_easy"
                android:textColor="#4AB3FF"
                android:textSize="10sp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp" />

            <TextView
                android:id="@+id/the_line_widget_btn_reset"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:gravity="center"
                android:text="↺"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

        </FrameLayout>

        <!-- Zone de jeu + overlays -->
        <FrameLayout
            android:layout_width="250dp"
            android:layout_height="250dp">

            <com.Atom2Universe.app.games.theline.TheLineBoardView
                android:id="@+id/the_line_widget_board"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="4dp" />

            <ProgressBar
                android:id="@+id/the_line_widget_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <!-- Overlay victoire -->
            <FrameLayout
                android:id="@+id/the_line_widget_result_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#CC0F172A"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/the_line_solved_label"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textColor="#22C55E" />

                    <TextView
                        android:id="@+id/the_line_widget_btn_new_game"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:gravity="center"
                        android:text="@string/the_line_new_game"
                        android:textColor="#22C55E"
                        android:textSize="12sp"
                        android:background="@drawable/bg_widget_arrow"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </FrameLayout>

            <!-- Overlay sélection difficulté -->
            <FrameLayout
                android:id="@+id/the_line_widget_reset_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#CC0F172A"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:text="@string/the_line_new_game"
                        android:textColor="#CBD5E1"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Sélection du mode -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:id="@+id/the_line_widget_mode_single"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/the_line_diff_simple"
                            android:textSize="12sp"
                            android:textColor="#7AD3FF"
                            android:background="@drawable/bg_widget_arrow"
                            android:clickable="true"
                            android:focusable="true" />

                        <View
                            android:layout_width="6dp"
                            android:layout_height="match_parent" />

                        <TextView
                            android:id="@+id/the_line_widget_mode_multi"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/the_line_diff_multi"
                            android:textSize="12sp"
                            android:textColor="#64748B"
                            android:background="@drawable/bg_widget_arrow"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/the_line_widget_diff_easy"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="@string/the_line_diff_easy"
                        android:textColor="#4AB3FF"
                        android:textSize="13sp"
                        android:background="@drawable/bg_widget_arrow"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/the_line_widget_diff_medium"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="@string/the_line_diff_medium"
                        android:textColor="#F6B93B"
                        android:textSize="13sp"
                        android:background="@drawable/bg_widget_arrow"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/the_line_widget_diff_hard"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="@string/the_line_diff_hard"
                        android:textColor="#FF6B6B"
                        android:textSize="13sp"
                        android:background="@drawable/bg_widget_arrow"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/the_line_widget_reset_cancel"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="@string/the_line_widget_cancel"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:background="@drawable/bg_widget_arrow"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </FrameLayout>

        </FrameLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
