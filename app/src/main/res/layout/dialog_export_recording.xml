<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/practice_export_filename"
        app:boxStrokeColor="?attr/a2uMidiAccent"
        app:hintTextColor="?attr/a2uMidiAccent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_filename"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textNoSuggestions"
            android:maxLines="1"
            android:textColor="@color/midi_text_primary" />

    </com.google.android.material.textfield.TextInputLayout>

    <CheckBox
        android:id="@+id/checkbox_midi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/practice_export_format_midi"
        android:textColor="@color/midi_text_primary"
        android:checked="true" />

    <CheckBox
        android:id="@+id/checkbox_wav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/practice_export_format_wav"
        android:textColor="@color/midi_text_primary" />

</LinearLayout>
