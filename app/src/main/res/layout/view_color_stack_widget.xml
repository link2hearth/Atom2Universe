<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/color_stack_widget_card"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#0F172A"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="#1F2937"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header : titre + sélecteur difficulté + bouton reset -->
        <FrameLayout
            android:id="@+id/color_stack_header_area"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/color_stack_btn_undo"
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:layout_gravity="start|center_vertical"
                android:gravity="center"
                android:text="↩"
                android:textColor="#64748B"
                android:textSize="15sp"
                android:clickable="true"
                android:focusable="true" />

            <!-- Label difficulté courante (non-cliquable, centré) -->
            <TextView
                android:id="@+id/color_stack_widget_difficulty"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="Facile"
                android:textColor="#4AB3FF"
                android:textSize="10sp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp" />

            <TextView
                android:id="@+id/color_stack_btn_reset"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:gravity="center"
                android:text="↺"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

        </FrameLayout>

        <!-- Zone de jeu + overlays — hauteur calculée par ColorStackView -->
        <FrameLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:minHeight="160dp">

            <com.Atom2Universe.app.games.colorstack.ColorStackView
                android:id="@+id/color_stack_widget_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Overlay victoire (caché par défaut) -->
            <FrameLayout
                android:id="@+id/color_stack_result_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#CC0F172A"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/color_stack_result_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textColor="#22C55E" />

                    <TextView
                        android:id="@+id/color_stack_btn_new_game"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:gravity="center"
                        android:text="Nouvelle partie"
                        android:textColor="#22C55E"
                        android:textSize="12sp"
                        android:background="@drawable/bg_widget_arrow"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

            </FrameLayout>

            <!-- Overlay sélection difficulté / nouvelle partie (caché par défaut) -->
            <FrameLayout
                android:id="@+id/color_stack_reset_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#CC0F172A"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:text="Nouvelle partie"
                        android:textColor="#CBD5E1"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/color_stack_diff_easy"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:gravity="center"
                        android:text="Facile"
                        android:textColor="#4AB3FF"
                        android:textSize="13sp"
                        android:background="@drawable/bg_widget_arrow"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/color_stack_diff_medium"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Moyen"
                        android:textColor="#F6B93B"
                        android:textSize="13sp"
                        android:background="@drawable/bg_widget_arrow"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/color_stack_diff_hard"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Difficile"
                        android:textColor="#FF6B6B"
                        android:textSize="13sp"
                        android:background="@drawable/bg_widget_arrow"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/color_stack_reset_cancel"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:text="✕ Annuler"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:background="@drawable/bg_widget_arrow"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </FrameLayout>

        </FrameLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
