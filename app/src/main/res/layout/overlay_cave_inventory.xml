<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:visibility="gone">

    <!-- Taille et position fixées en code (82% × 84% de l'écran, centré) -->
    <LinearLayout
        android:id="@+id/cave_inv_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:clickable="true"
        android:focusable="true"
        android:elevation="8dp"
        android:padding="0dp">

        <!-- ===== GAUCHE : info item sélectionné ===== -->
        <!-- Colonne transparente match_parent, contenu dark uniquement sur wrap_content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.9"
            android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/midi_surface">

            <!-- Header section Objet -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cave_inv_info_header"
                android:textColor="@color/midi_text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="7dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:background="#1AFFFFFF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="?attr/a2uMidiAccent" />

            <!-- Contenu -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="8dp">

                <!-- Preview slot stylé -->
                <FrameLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#33FFFFFF">

                    <View
                        android:id="@+id/cave_inv_info_sprite"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_margin="3dp" />
                </FrameLayout>

                <TextView
                    android:id="@+id/cave_inv_info_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/midi_text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="6dp"
                    android:text="@string/cave_inv_info_empty" />

                <TextView
                    android:id="@+id/cave_inv_info_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginTop="2dp" />

                <View
                    android:id="@+id/cave_inv_info_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#33FFFFFF"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="6dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/cave_inv_info_ingredients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#AAFFFFFF"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.3"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#2AFFFFFF" />

        <!-- ===== CENTRE : inventaire scrollable + barre active ===== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:background="@color/midi_surface_variant"
            android:orientation="vertical">

            <!-- Header Inventaire -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cave_inventory_title"
                android:textColor="@color/midi_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="10dp"
                android:background="#1AFFFFFF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="?attr/a2uMidiAccent" />

            <!-- Grille scrollable -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/cave_inv_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="4dp"
                android:clipToPadding="false" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF" />

            <!-- Barre active : 9 slots -->
            <LinearLayout
                android:id="@+id/cave_inv_active_row"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:padding="4dp"
                android:background="#15FFFFFF" />

        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#2AFFFFFF" />

        <!-- ===== DROITE : crafting ===== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.8"
            android:orientation="vertical"
            android:background="@color/midi_surface">

            <!-- Header Fabrication -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cave_inv_crafting_header"
                android:textColor="@color/midi_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="10dp"
                android:background="#1AFFFFFF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="?attr/a2uMidiAccent" />

            <TextView
                android:id="@+id/cave_inv_crafting_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cave_inv_crafting_empty"
                android:textColor="#66FFFFFF"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:visibility="visible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/cave_inv_crafting_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="6dp"
                android:clipToPadding="false"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
