<?xml version="1.0" encoding="utf-8"?>
<!-- Root sans background ni clickable : les touches dans la zone hotbar (60dp bas) passent au HUD -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone">

    <!-- Zone dim couvrant tout sauf la hotbar -->
    <FrameLayout
        android:id="@+id/cave_inv_dim_area"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="60dp"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true">

        <!-- Panel principal (horizontal : info | grille paginée | crafting) -->
        <LinearLayout
            android:id="@+id/cave_inv_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="8dp"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:elevation="8dp">

            <!-- ===== GAUCHE : info item sélectionné ===== -->
            <LinearLayout
                android:id="@+id/cave_inv_info_column"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.9"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/midi_surface">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/cave_inv_info_header"
                        android:textColor="@color/midi_text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:paddingTop="8dp"
                        android:paddingBottom="7dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:background="#1AFFFFFF" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="?attr/a2uMidiAccent" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="8dp">

                        <FrameLayout
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:background="#33FFFFFF">

                            <View
                                android:id="@+id/cave_inv_info_sprite"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_margin="3dp" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/cave_inv_info_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/midi_text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="6dp"
                            android:text="@string/cave_inv_info_empty" />

                        <TextView
                            android:id="@+id/cave_inv_info_count"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#CCFFFFFF"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="2dp" />

                        <View
                            android:id="@+id/cave_inv_info_divider"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#33FFFFFF"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="6dp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/cave_inv_info_ingredients"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#AAFFFFFF"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:lineSpacingMultiplier="1.3"
                            android:visibility="gone" />

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#2AFFFFFF" />

            <!-- ===== CENTRE : grille paginée ===== -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="4"
                android:background="@color/midi_surface_variant"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cave_inventory_title"
                    android:textColor="@color/midi_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingTop="10dp"
                    android:paddingBottom="8dp"
                    android:background="#1AFFFFFF" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="?attr/a2uMidiAccent" />

                <!-- ViewPager2 : une page = grille qui remplit l'espace -->
                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/cave_inv_pager"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Indicateur de page : "2 / 4" -->
                <TextView
                    android:id="@+id/cave_inv_page_indicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#88FFFFFF"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />

            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#2AFFFFFF" />

            <!-- ===== DROITE : crafting / sell ===== -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.8"
                android:orientation="vertical"
                android:background="@color/midi_surface">

                <TextView
                    android:id="@+id/cave_inv_right_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cave_inv_crafting_header"
                    android:textColor="@color/midi_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingTop="10dp"
                    android:paddingBottom="8dp"
                    android:background="#1AFFFFFF" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="?attr/a2uMidiAccent" />

                <TextView
                    android:id="@+id/cave_inv_crafting_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cave_inv_crafting_empty"
                    android:textColor="#66FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="visible" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/cave_inv_crafting_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:padding="6dp"
                    android:clipToPadding="false"
                    android:visibility="gone" />

                <!-- Panneau Sell (visible uniquement quand une arme est sélectionnée) -->
                <LinearLayout
                    android:id="@+id/cave_inv_sell_panel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="12dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/cave_inv_sell_price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/cave_inv_sell_btn"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:text="@string/cave_inv_sell_btn"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:backgroundTint="#CC8800" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
