<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/cave_inv_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@color/midi_surface"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/cave_inventory_title"
            android:textColor="@color/midi_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Grille unifiée 9×4 : 3 lignes inventaire + 1 ligne active (largeur fixée en code) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/cave_inv_recycler"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>

</FrameLayout>
