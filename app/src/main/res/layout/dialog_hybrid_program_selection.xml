<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Description -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/hybrid_program_selection_desc"
        android:textSize="13sp"
        android:textColor="?android:attr/textColorSecondary"
        android:padding="16dp" />

    <!-- Drums checkbox -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">

        <CheckBox
            android:id="@+id/checkbox_drums_sf2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hybrid_drums_channel_9"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hybrid_drums_desc"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?android:attr/listDivider" />

    <!-- Quick actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_select_none"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hybrid_select_none"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_select_all"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hybrid_select_all"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Instrument families list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_instruments"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="300dp"
        android:maxHeight="400dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- Summary -->
    <TextView
        android:id="@+id/text_selection_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/hybrid_selection_summary"
        android:textSize="12sp"
        android:textColor="?attr/colorPrimary"
        android:textStyle="italic"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:background="#1A000000" />

</LinearLayout>
