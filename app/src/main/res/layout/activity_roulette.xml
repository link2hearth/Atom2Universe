<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0014">

    <!-- ── Header ───────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/roulette_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:background="#12000030"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/roulette_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/roulette_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:gravity="center"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/roulette_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚛ 0"
            android:textSize="16sp"
            android:textColor="#B0BEC5"
            android:textStyle="bold"
            android:minWidth="80dp"
            android:gravity="end" />
    </LinearLayout>

    <!-- ── Tableau des gains ────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/roulette_paytable"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        app:layout_constraintTop_toBottomOf="@id/roulette_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/roulette_pay_suit"
            android:textSize="11sp"
            android:textColor="#9575CD"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/roulette_pay_color"
            android:textSize="11sp"
            android:textColor="#7986CB"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/roulette_pay_joker"
            android:textSize="11sp"
            android:textColor="#FFD700"
            android:gravity="center" />
    </LinearLayout>

    <!-- ── Grille 3×3 (3 lignes de LinearLayout) ───────────────────────── -->
    <LinearLayout
        android:id="@+id/roulette_grid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/roulette_paytable"
        app:layout_constraintBottom_toTopOf="@id/roulette_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Ligne 0 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <TextView android:id="@+id/roulette_cell_00" style="@style/RouletteCell" />
            <TextView android:id="@+id/roulette_cell_01" style="@style/RouletteCell" />
            <TextView android:id="@+id/roulette_cell_02" style="@style/RouletteCell" />
        </LinearLayout>

        <!-- Ligne 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <TextView android:id="@+id/roulette_cell_10" style="@style/RouletteCell" />
            <TextView android:id="@+id/roulette_cell_11" style="@style/RouletteCell" />
            <TextView android:id="@+id/roulette_cell_12" style="@style/RouletteCell" />
        </LinearLayout>

        <!-- Ligne 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <TextView android:id="@+id/roulette_cell_20" style="@style/RouletteCell" />
            <TextView android:id="@+id/roulette_cell_21" style="@style/RouletteCell" />
            <TextView android:id="@+id/roulette_cell_22" style="@style/RouletteCell" />
        </LinearLayout>

    </LinearLayout>

    <!-- ── Statut ────────────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/roulette_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="#B0BEC5"
        android:paddingVertical="6dp"
        app:layout_constraintBottom_toTopOf="@id/roulette_last_win"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/roulette_last_win"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="13sp"
        android:textColor="#FFD700"
        android:textStyle="bold"
        android:paddingBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/roulette_bet_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Mise ──────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/roulette_bet_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp"
        app:layout_constraintBottom_toTopOf="@id/roulette_spin_btn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/roulette_bet_1"
            style="@style/RouletteBetButton"
            android:text="1⚛" />

        <TextView
            android:id="@+id/roulette_bet_2"
            style="@style/RouletteBetButton"
            android:text="2⚛" />

        <TextView
            android:id="@+id/roulette_bet_5"
            style="@style/RouletteBetButton"
            android:text="5⚛" />

        <TextView
            android:id="@+id/roulette_bet_10"
            style="@style/RouletteBetButton"
            android:text="10⚛" />

        <TextView
            android:id="@+id/roulette_bet_25"
            style="@style/RouletteBetButton"
            android:text="25⚛" />

    </LinearLayout>

    <!-- ── Bouton SPIN ───────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/roulette_spin_btn"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:gravity="center"
        android:text="@string/roulette_spin"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:fontFamily="monospace"
        android:background="@drawable/roulette_spin_bg"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
