<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0014">

    <!-- ── Header ───────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/roulette_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:background="#12000030"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/roulette_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back" />

        <!-- Zone centrale : status + last_win empilés -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/roulette_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#B0BEC5" />

            <TextView
                android:id="@+id/roulette_last_win"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#FFD700"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/roulette_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚛ 0"
            android:textSize="16sp"
            android:textColor="#B0BEC5"
            android:textStyle="bold"
            android:minWidth="80dp"
            android:gravity="end" />
    </LinearLayout>

    <!-- ── Grille 3×3 (ImageViews) ─────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/roulette_grid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/roulette_header"
        app:layout_constraintBottom_toTopOf="@id/roulette_bet_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Ligne 0 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <ImageView android:id="@+id/roulette_cell_00" style="@style/RouletteCell" />
            <ImageView android:id="@+id/roulette_cell_01" style="@style/RouletteCell" />
            <ImageView android:id="@+id/roulette_cell_02" style="@style/RouletteCell" />
        </LinearLayout>

        <!-- Ligne 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <ImageView android:id="@+id/roulette_cell_10" style="@style/RouletteCell" />
            <ImageView android:id="@+id/roulette_cell_11" style="@style/RouletteCell" />
            <ImageView android:id="@+id/roulette_cell_12" style="@style/RouletteCell" />
        </LinearLayout>

        <!-- Ligne 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <ImageView android:id="@+id/roulette_cell_20" style="@style/RouletteCell" />
            <ImageView android:id="@+id/roulette_cell_21" style="@style/RouletteCell" />
            <ImageView android:id="@+id/roulette_cell_22" style="@style/RouletteCell" />
        </LinearLayout>

    </LinearLayout>

    <!-- ── Mise ──────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/roulette_bet_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp"
        app:layout_constraintBottom_toTopOf="@id/roulette_spin_btn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView android:id="@+id/roulette_bet_1"  style="@style/RouletteBetButton" android:text="1⚛" />
        <TextView android:id="@+id/roulette_bet_2"  style="@style/RouletteBetButton" android:text="2⚛" />
        <TextView android:id="@+id/roulette_bet_5"  style="@style/RouletteBetButton" android:text="5⚛" />
        <TextView android:id="@+id/roulette_bet_10" style="@style/RouletteBetButton" android:text="10⚛" />
        <TextView android:id="@+id/roulette_bet_25" style="@style/RouletteBetButton" android:text="25⚛" />

    </LinearLayout>

    <!-- ── Bouton SPIN ───────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/roulette_spin_btn"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:gravity="center"
        android:text="@string/roulette_spin"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:fontFamily="monospace"
        android:background="@drawable/roulette_spin_bg"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Overlay Victoire ──────────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/roulette_win_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#BB000022"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/roulette_win_card"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/roulette_win_card_bg"
            android:padding="36dp"
            android:elevation="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/roulette_win_overlay_title"
                android:textSize="52sp"
                android:textStyle="bold"
                android:textColor="#FFD700"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/roulette_win_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/roulette_win_overlay_tap"
                android:textSize="13sp"
                android:textColor="#777777"
                android:layout_marginTop="24dp" />

        </LinearLayout>
    </FrameLayout>

    <!-- ── Confettis (au-dessus de tout) ────────────────────────────────── -->
    <com.Atom2Universe.app.games.roulette.ConfettiView
        android:id="@+id/roulette_confetti"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:clickable="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
