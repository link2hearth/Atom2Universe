<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/music_widget_card"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#0F172A"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <!-- Conteneur de taille fixe : le visualiseur s'étire dedans sans déborder -->
    <FrameLayout
        android:layout_width="280dp"
        android:layout_height="280dp">

        <!-- Visualiseur : remplit tout le conteneur fixe -->
        <com.Atom2Universe.app.music.view.AudioVisualizerView
            android:id="@+id/music_widget_visualizer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- Fond sombre quand pas de visualiseur -->
        <View
            android:id="@+id/music_widget_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0F172A" />

        <!-- Overlay gradient haut → transparent (pour lisibilité du header) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_gravity="top"
            android:background="@drawable/music_widget_gradient_top" />

        <!-- Overlay gradient transparent → bas (pour lisibilité des contrôles) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="bottom"
            android:background="@drawable/music_widget_gradient_bottom" />

        <!-- Overlay paroles : transparent, positionne les vues de texte -->
        <FrameLayout
            android:id="@+id/music_widget_lyrics_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="52dp"
            android:padding="10dp"
            android:visibility="gone">

            <!-- Non-synced : texte complet scrollable avec fond sous le texte -->
            <ScrollView
                android:id="@+id/music_widget_lyrics_scroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/music_widget_lyrics_bg"
                android:padding="8dp"
                android:overScrollMode="never"
                android:visibility="gone">

                <TextView
                    android:id="@+id/music_widget_lyrics_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#CBD5E1"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.6" />

            </ScrollView>

            <!-- Synced : fond surlignage autour du texte uniquement -->
            <TextView
                android:id="@+id/music_widget_lyrics_sync_line"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/music_widget_lyrics_bg"
                android:padding="12dp"
                android:gravity="center"
                android:textColor="#F1F5F9"
                android:textSize="13sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.5"
                android:visibility="gone" />

        </FrameLayout>

        <!-- "Aucune musique" : centré, visible uniquement sans piste -->
        <TextView
            android:id="@+id/music_widget_no_music"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/music_widget_no_music"
            android:textColor="#64748B"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- ── HEADER (drag + titre + sélecteur) ── -->
        <FrameLayout
            android:id="@+id/music_widget_header"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_gravity="top"
            android:clickable="true"
            android:focusable="true">

            <!-- Bouton bibliothèque (coin supérieur gauche) -->
            <TextView
                android:id="@+id/music_widget_lib_btn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="4dp"
                android:gravity="center"
                android:text="≡"
                android:textColor="#64748B"
                android:textSize="17sp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/music_widget_lib_btn_desc" />

            <!-- Infos piste (padding ajusté pour 2 boutons à droite) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:paddingStart="44dp"
                android:paddingEnd="76dp">

                <TextView
                    android:id="@+id/music_widget_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="marquee"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:textColor="#F1F5F9"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/music_widget_artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="#94A3B8"
                    android:textSize="10sp" />

            </LinearLayout>

            <!-- Boutons droits : sélecteur de visuel + paroles -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="end|center_vertical"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/music_widget_viz_btn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="◈"
                    android:textColor="#64748B"
                    android:textSize="15sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/music_widget_viz_selector_desc" />

                <TextView
                    android:id="@+id/music_widget_lyrics_btn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="4dp"
                    android:gravity="center"
                    android:text="♪"
                    android:textColor="#64748B"
                    android:textSize="15sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/music_widget_lyrics_btn_desc" />

            </LinearLayout>

        </FrameLayout>

        <!-- ── CONTRÔLES BAS (prev / play-pause / next) ── -->
        <LinearLayout
            android:id="@+id/music_widget_controls"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/music_widget_btn_prev"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="9dp"
                android:src="@drawable/ic_skip_previous"
                app:tint="#CBD5E1"
                android:contentDescription="@string/music_widget_btn_prev_desc" />

            <ImageButton
                android:id="@+id/music_widget_btn_play_pause"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"
                android:src="@drawable/ic_play"
                app:tint="#F1F5F9"
                android:contentDescription="@string/music_widget_btn_play_pause_desc" />

            <ImageButton
                android:id="@+id/music_widget_btn_next"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="9dp"
                android:src="@drawable/ic_skip_next"
                app:tint="#CBD5E1"
                android:contentDescription="@string/music_widget_btn_next_desc" />

        </LinearLayout>

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
