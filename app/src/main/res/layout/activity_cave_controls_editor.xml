<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DD111111">

    <!-- Canvas draggable = hauteur identique à la zone de jeu (écran moins hotbar 60dp) -->
    <FrameLayout
        android:id="@+id/cave_editor_canvas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="60dp" />

    <!-- Simulation de la hotbar en bas -->
    <View
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:background="#BB000000" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:text="@string/cave_controls_hotbar_mock"
        android:textColor="#44FFFFFF"
        android:textSize="11sp" />

    <!-- Indice centre -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:text="@string/cave_controls_hint"
        android:textColor="#33FFFFFF"
        android:textSize="12sp" />

    <!-- Barre supérieure -->
    <LinearLayout
        android:id="@+id/cave_editor_topbar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_gravity="top"
        android:background="#EE000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/cave_controls_editor_title"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/cave_editor_btn_reset"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="#55FF4444"
            android:paddingHorizontal="12dp"
            android:text="@string/cave_controls_reset"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/cave_editor_btn_save"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="#554499FF"
            android:paddingHorizontal="12dp"
            android:text="@string/cave_controls_save"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Panneau bas : bouton sélectionné + taille -->
    <LinearLayout
        android:id="@+id/cave_editor_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="60dp"
        android:background="#EE000000"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/cave_editor_selected_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/cave_controls_select_hint"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/cave_controls_size"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp" />

            <SeekBar
                android:id="@+id/cave_editor_seekbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="60"
                android:progress="24" />

            <TextView
                android:id="@+id/cave_editor_size_value"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:gravity="end"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
