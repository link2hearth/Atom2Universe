<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/album_art"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_music_album_placeholder"
        android:contentDescription="@string/music_album_art"
        android:background="@drawable/music_album_art_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageView
        android:id="@+id/favorite_icon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_favorite_filled"
        android:contentDescription="@string/music_add_to_favorites"
        android:visibility="gone"
        app:tint="@color/music_album_favorite"
        app:layout_constraintEnd_toEndOf="@id/album_art"
        app:layout_constraintBottom_toBottomOf="@id/album_art"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/album_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="@color/music_text_primary"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        tools:text="Album Name"
        app:layout_constraintStart_toEndOf="@id/album_art"
        app:layout_constraintEnd_toStartOf="@id/btn_shuffle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/album_info" />

    <TextView
        android:id="@+id/album_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/music_text_secondary"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        tools:text="12 tracks - 45 min"
        app:layout_constraintStart_toEndOf="@id/album_art"
        app:layout_constraintEnd_toStartOf="@id/btn_shuffle"
        app:layout_constraintTop_toBottomOf="@id/album_name"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Quick action buttons -->
    <ImageView
        android:id="@+id/btn_shuffle"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="6dp"
        android:src="@drawable/ic_shuffle"
        android:contentDescription="@string/music_shuffle"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="@color/music_text_secondary"
        app:layout_constraintEnd_toStartOf="@id/btn_play"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageView
        android:id="@+id/btn_play"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="6dp"
        android:src="@drawable/ic_play"
        android:contentDescription="@string/music_play_all"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="?attr/a2uMusicAccent"
        app:layout_constraintEnd_toStartOf="@id/arrow_icon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageView
        android:id="@+id/arrow_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_chevron_right"
        android:contentDescription="@string/music_open"
        app:tint="@color/music_text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
