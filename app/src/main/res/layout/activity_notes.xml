<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/startup_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0F172A"
        app:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/nav_back"
                android:layout_width="44dp"
                android:layout_height="match_parent"
                android:src="@drawable/ic_arrow_back_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#94A3B8"
                android:contentDescription="@string/notes_back" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <HorizontalScrollView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:fillViewport="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/nav_home"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="@string/notes_nav_home"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/nav_groups"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="@string/notes_nav_groups"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/nav_favorites"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="@string/notes_nav_favorites"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/nav_tags"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="@string/notes_nav_tags"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/nav_search"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="@string/notes_nav_search"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:id="@+id/notes_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
