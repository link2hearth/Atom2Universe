<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060914">

    <com.Atom2Universe.app.games.orbite.OrbiteView
        android:id="@+id/orbite_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- HUD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="20dp">

        <TextView
            android:id="@+id/orbite_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#36E1FF"
            android:textSize="40sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/orbite_best"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#557799"
            android:textSize="13sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Start overlay -->
    <LinearLayout
        android:id="@+id/orbite_overlay_start"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#C0060914">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/orbite_title"
            android:textColor="#36E1FF"
            android:textSize="40sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/orbite_subtitle"
            android:textColor="#7CFFCB"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:paddingHorizontal="40dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/orbite_instructions"
            android:textColor="#778899"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingHorizontal="40dp"
            android:layout_marginBottom="40dp" />

        <Button
            android:id="@+id/orbite_btn_start"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:text="@string/orbite_btn_start"
            android:backgroundTint="#36E1FF"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/orbite_btn_back_start"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:text="@string/orbite_btn_back"
            android:backgroundTint="#222233"
            android:textColor="#AAAAAA" />
    </LinearLayout>

    <!-- Game Over overlay -->
    <LinearLayout
        android:id="@+id/orbite_overlay_game_over"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#C0060914"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/orbite_game_over"
            android:textColor="#FF5A6E"
            android:textSize="38sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/orbite_final_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCEEFF"
            android:textSize="22sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/orbite_best_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#7CFFCB"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/orbite_reward"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFB347"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:visibility="gone"
            android:layout_marginBottom="40dp" />

        <Button
            android:id="@+id/orbite_btn_restart"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:text="@string/orbite_btn_restart"
            android:backgroundTint="#36E1FF"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/orbite_btn_back_gameover"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:text="@string/orbite_btn_back"
            android:backgroundTint="#222233"
            android:textColor="#AAAAAA" />
    </LinearLayout>

</FrameLayout>
