<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/startup_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/back_button_desc" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/othello_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/startup_text_primary"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Score -->
    <TextView
        android:id="@+id/othello_score"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="4dp"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/startup_text_primary" />

    <!-- Status -->
    <TextView
        android:id="@+id/othello_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textSize="13sp"
        android:textColor="@color/startup_text_secondary" />

    <!-- Board -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp">

        <com.Atom2Universe.app.games.othello.OthelloBoardView
            android:id="@+id/othello_board"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center">

        <Button
            android:id="@+id/othello_mode_button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:textSize="13sp"
            android:backgroundTint="#2E7D32" />

        <Button
            android:id="@+id/othello_new_button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/othello_new_game"
            android:textSize="13sp"
            android:backgroundTint="#455A64" />
    </LinearLayout>

</LinearLayout>
