<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/music_background">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/music_surface"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/music_settings"
        app:titleTextColor="@color/music_text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section: Tri -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/music_settings_section_sorting"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="?android:attr/colorAccent"
                android:layout_marginBottom="12dp" />

            <!-- Option: Tri des albums -->
            <LinearLayout
                android:id="@+id/option_album_sort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_sort_albums"
                        android:textSize="16sp"
                        android:textColor="?android:attr/textColorPrimary" />

                    <TextView
                        android:id="@+id/text_album_sort_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="?android:attr/textColorSecondary"
                    android:importantForAccessibility="no" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginVertical="8dp" />

            <!-- Section: Affichage -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/music_settings_section_display"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="?android:attr/colorAccent"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <!-- Option: Afficher le nombre d'écoutes -->
            <LinearLayout
                android:id="@+id/option_show_play_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_settings_show_play_count"
                        android:textSize="16sp"
                        android:textColor="?android:attr/textColorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_settings_show_play_count_desc"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/text_play_count_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?attr/a2uMusicAccent"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_show_play_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginVertical="8dp" />

            <!-- Section: Cloud Sync -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/music_settings_section_cloud_sync"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="?android:attr/colorAccent"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <!-- Option: Google Account -->
            <LinearLayout
                android:id="@+id/option_google_account"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_settings_google_account"
                        android:textSize="16sp"
                        android:textColor="?android:attr/textColorPrimary" />

                    <TextView
                        android:id="@+id/text_google_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_settings_not_signed_in"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sign_in_out"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/music_settings_sign_in"
                    android:textSize="16sp"
                    android:textColor="?attr/a2uMusicAccent"
                    app:strokeColor="?attr/a2uMusicAccent"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>

            <!-- Option: Enable Sync (visible only when signed in) -->
            <LinearLayout
                android:id="@+id/option_enable_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_settings_enable_sync"
                        android:textSize="16sp"
                        android:textColor="?android:attr/textColorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_settings_sync_description"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_enable_sync"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- Last Sync Status -->
            <TextView
                android:id="@+id/text_last_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/music_settings_last_sync_never"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingHorizontal="12dp"
                android:visibility="gone" />

            <!-- Sync Now Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sync_now"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/music_settings_sync_now"
                android:textSize="16sp"
                android:textColor="?attr/a2uMusicAccent"
                app:strokeColor="?attr/a2uMusicAccent"
                android:layout_marginTop="8dp"
                android:layout_marginStart="12dp"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <!-- Reset Play Counts Button (for bug fix) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset_play_counts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/music_settings_reset_play_counts"
                android:textSize="14sp"
                android:textColor="#FF5252"
                app:strokeColor="#FF5252"
                android:layout_marginTop="8dp"
                android:layout_marginStart="12dp"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <!-- Option: Réseau Wi-Fi de confiance (sync LAN) -->
            <LinearLayout
                android:id="@+id/option_trusted_wifi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_settings_trusted_wifi"
                        android:textSize="16sp"
                        android:textColor="?android:attr/textColorPrimary" />

                    <TextView
                        android:id="@+id/text_trusted_wifi_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_trusted_wifi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginVertical="8dp" />

            <!-- Option: Recherche auto des paroles -->
            <LinearLayout
                android:id="@+id/option_auto_fetch_lyrics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lyrics_auto_fetch"
                        android:textSize="16sp"
                        android:textColor="?android:attr/textColorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lyrics_auto_fetch_description"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/text_auto_fetch_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?attr/a2uMusicAccent"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_auto_fetch_lyrics"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- Lyrics API Configuration Section (appears when auto-fetch is enabled) -->
            <LinearLayout
                android:id="@+id/section_lyrics_api"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/lyrics_api_section_title"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/colorAccent"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/lyrics_api_section_desc"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginBottom="12dp" />

                <!-- API 1 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/lyrics_api_primary_label"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="?attr/a2uMusicAccent"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_lyrics_api_primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/lyrics_api_url_hint"
                        android:inputType="textUri"
                        android:textSize="14sp"
                        android:imeOptions="actionNext" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- API 1 Advanced Options Toggle -->
                <TextView
                    android:id="@+id/toggle_api1_advanced"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lyrics_api_advanced_options"
                    android:textSize="12sp"
                    android:textColor="?attr/a2uMusicAccent"
                    android:drawableEnd="@drawable/ic_expand_more"
                    android:drawablePadding="4dp"
                    android:padding="4dp"
                    android:layout_marginBottom="4dp"
                    android:background="?attr/selectableItemBackground" />

                <!-- API 1 Advanced Options Container -->
                <LinearLayout
                    android:id="@+id/container_api1_advanced"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/lyrics_api_headers_label"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="?attr/a2uMusicAccent"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_lyrics_api_primary_headers"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/lyrics_api_headers_hint"
                            android:inputType="textMultiLine"
                            android:minLines="2"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/lyrics_api_synced_path_label"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="?attr/a2uMusicAccent"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_lyrics_api_primary_synced_path"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/lyrics_api_synced_path_hint"
                            android:inputType="text"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/lyrics_api_lyrics_path_label"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="?attr/a2uMusicAccent"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_lyrics_api_primary_lyrics_path"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/lyrics_api_lyrics_path_hint"
                            android:inputType="text"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/lyrics_api_advanced_help"
                        android:textSize="11sp"
                        android:textColor="?android:attr/textColorSecondary" />

                </LinearLayout>

                <!-- API 2 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/lyrics_api_fallback_label"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="?attr/a2uMusicAccent"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_lyrics_api_fallback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/lyrics_api_url_hint"
                        android:inputType="textUri"
                        android:textSize="14sp"
                        android:imeOptions="actionDone" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- API 2 Advanced Options Toggle -->
                <TextView
                    android:id="@+id/toggle_api2_advanced"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lyrics_api_advanced_options"
                    android:textSize="12sp"
                    android:textColor="?attr/a2uMusicAccent"
                    android:drawableEnd="@drawable/ic_expand_more"
                    android:drawablePadding="4dp"
                    android:padding="4dp"
                    android:layout_marginBottom="4dp"
                    android:background="?attr/selectableItemBackground" />

                <!-- API 2 Advanced Options Container -->
                <LinearLayout
                    android:id="@+id/container_api2_advanced"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/lyrics_api_headers_label"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="?attr/a2uMusicAccent"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_lyrics_api_fallback_headers"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/lyrics_api_headers_hint"
                            android:inputType="textMultiLine"
                            android:minLines="2"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/lyrics_api_synced_path_label"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="?attr/a2uMusicAccent"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_lyrics_api_fallback_synced_path"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/lyrics_api_synced_path_hint"
                            android:inputType="text"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/lyrics_api_lyrics_path_label"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="?attr/a2uMusicAccent"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_lyrics_api_fallback_lyrics_path"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/lyrics_api_lyrics_path_hint"
                            android:inputType="text"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/lyrics_api_advanced_help"
                        android:textSize="11sp"
                        android:textColor="?android:attr/textColorSecondary" />

                </LinearLayout>

                <!-- Test APIs Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_test_lyrics_api"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lyrics_api_test_button"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    app:icon="@drawable/ic_check"
                    app:iconGravity="start"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <!-- Test Result Text -->
                <TextView
                    android:id="@+id/text_api_test_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

            </LinearLayout>

            <View
                android:id="@+id/divider_advanced"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginVertical="8dp" />

            <!-- Section: Avancé -->
            <TextView
                android:id="@+id/text_section_advanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/music_settings_section_advanced"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="?android:attr/colorAccent"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <!-- Option: Écrire dans les tags ID3/POPM -->
            <LinearLayout
                android:id="@+id/option_write_tags_to_files"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_settings_write_tags_to_files"
                        android:textSize="16sp"
                        android:textColor="?android:attr/textColorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_settings_write_tags_to_files_desc"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/text_write_tags_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?attr/a2uMusicAccent"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_write_tags_to_files"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginVertical="8dp" />

            <!-- Option: Migration des tags ID3 -->
            <LinearLayout
                android:id="@+id/option_tag_migration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_settings_tag_migration"
                        android:textSize="16sp"
                        android:textColor="?android:attr/textColorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_settings_tag_migration_desc"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="?android:attr/textColorSecondary"
                    android:importantForAccessibility="no" />

            </LinearLayout>

            <!-- Option: Sync pending POPM tags -->
            <LinearLayout
                android:id="@+id/option_sync_pending_popm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_settings_sync_pending_popm"
                        android:textSize="16sp"
                        android:textColor="?android:attr/textColorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_settings_sync_pending_popm_desc"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="?android:attr/textColorSecondary"
                    android:importantForAccessibility="no" />

            </LinearLayout>

            <View
                android:id="@+id/divider_backup"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginVertical="16dp"
                android:visibility="gone" />

            <!-- Section: Backup (visible only when signed in) -->
            <TextView
                android:id="@+id/text_backup_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/music_settings_section_backup"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="?android:attr/colorAccent"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <!-- Option: Primary Device -->
            <LinearLayout
                android:id="@+id/option_primary_device"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_settings_primary_device"
                        android:textSize="16sp"
                        android:textColor="?android:attr/textColorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_settings_primary_device_desc"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_primary_device"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- Last Backup Info -->
            <TextView
                android:id="@+id/text_last_backup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/music_settings_last_backup_never"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingHorizontal="12dp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <!-- Restore from Cloud Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_restore_backup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/music_settings_restore_backup"
                android:textSize="16sp"
                android:textColor="?attr/a2uMusicAccent"
                app:strokeColor="?attr/a2uMusicAccent"
                android:layout_marginTop="12dp"
                android:layout_marginStart="12dp"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <!-- Delete Cloud Data Button (danger zone) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_cloud_data"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/music_settings_delete_cloud_data"
                android:textSize="14sp"
                android:textColor="#FF5252"
                app:strokeColor="#FF5252"
                android:layout_marginTop="24dp"
                android:layout_marginStart="12dp"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- Navidrome Section -->
        <LinearLayout
            android:id="@+id/section_navidrome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/navidrome_settings"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="?android:attr/colorAccent"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="?attr/a2uMusicAccent"
                android:hint="@string/navidrome_server_url">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_navidrome_server_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textSize="14sp"
                    android:imeOptions="actionNext" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="?attr/a2uMusicAccent"
                android:hint="@string/navidrome_username">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_navidrome_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textNoSuggestions"
                    android:textSize="14sp"
                    android:imeOptions="actionNext" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="?attr/a2uMusicAccent"
                android:hint="@string/navidrome_password"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_navidrome_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textSize="14sp"
                    android:imeOptions="actionDone" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_test_navidrome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/navidrome_test_connection"
                android:layout_marginBottom="4dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>

    </LinearLayout>

    </ScrollView>

</LinearLayout>
