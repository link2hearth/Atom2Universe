<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A18">

    <!-- ── Header ──────────────────────────────────────────────────────── -->

    <LinearLayout
        android:id="@+id/escape_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/escape_btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/escape_back"
            app:tint="#AACCFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/escape_title"
            android:textColor="#CCE6FF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:singleLine="true"
            android:paddingStart="4dp" />

        <!-- Difficulty buttons -->
        <Button
            android:id="@+id/escape_btn_easy"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/escape_diff_easy"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@android:color/transparent"
            style="?attr/borderlessButtonStyle" />

        <Button
            android:id="@+id/escape_btn_medium"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/escape_diff_medium"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@android:color/transparent"
            style="?attr/borderlessButtonStyle" />

        <Button
            android:id="@+id/escape_btn_hard"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/escape_diff_hard"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@android:color/transparent"
            style="?attr/borderlessButtonStyle" />

    </LinearLayout>

    <!-- ── Info row (turns + orbs + difficulty + new) ───────────────────── -->

    <LinearLayout
        android:id="@+id/escape_info_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        app:layout_constraintTop_toBottomOf="@id/escape_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/escape_tv_difficulty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#88AABB"
            android:textSize="12sp"
            android:paddingEnd="8dp" />

        <TextView
            android:id="@+id/escape_tv_turns"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AADDFF"
            android:textSize="12sp"
            android:paddingEnd="8dp"
            android:text="@string/escape_turns_label_zero" />

        <TextView
            android:id="@+id/escape_tv_orbs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFDD88"
            android:textSize="12sp" />

        <Button
            android:id="@+id/escape_btn_new"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/escape_btn_new"
            android:textSize="11sp"
            android:textColor="#AACCFF"
            android:background="@android:color/transparent"
            style="?attr/borderlessButtonStyle" />

    </LinearLayout>

    <!-- ── Status message ────────────────────────────────────────────────── -->

    <TextView
        android:id="@+id/escape_tv_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="12sp"
        android:textColor="#AADDCC"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="2dp"
        android:ellipsize="end"
        android:maxLines="2"
        app:layout_constraintTop_toBottomOf="@id/escape_info_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Maze view (fills all remaining space) ─────────────────────────── -->

    <com.Atom2Universe.app.games.escapelabyrinth.EscapeLabyrinthView
        android:id="@+id/escape_maze_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/escape_tv_status"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Loading overlay ───────────────────────────────────────────────── -->

    <FrameLayout
        android:id="@+id/escape_loading_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#AA0A0A18"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/escape_tv_status"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="#4499FF" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
