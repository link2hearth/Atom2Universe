<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/crypto_widget_background"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/crypto_chart_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/crypto_back"
            android:src="@drawable/ic_arrow_back_24"
            app:tint="?attr/a2uMidiAccent" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/crypto_chart_asset_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/crypto_chart_asset_btc"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/crypto_widget_btc_label" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/crypto_chart_asset_eth"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/crypto_widget_eth_label" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/crypto_chart_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/crypto_widget_value"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="67 432.10 USD" />

            <TextView
                android:id="@+id/crypto_chart_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textSize="13sp"
                tools:text="+2.34 %" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1">

        <com.Atom2Universe.app.crypto.CandleChartView
            android:id="@+id/crypto_chart_candles"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/crypto_chart_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="@color/crypto_widget_status"
            android:textSize="14sp"
            android:visibility="gone"
            tools:text="@string/crypto_widget_loading"
            tools:visibility="visible" />
    </FrameLayout>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/crypto_chart_interval_group_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crypto_chart_int_1m"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/crypto_chart_int_1m" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crypto_chart_int_5m"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/crypto_chart_int_5m" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crypto_chart_int_15m"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/crypto_chart_int_15m" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crypto_chart_int_1h"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/crypto_chart_int_1h" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crypto_chart_int_4h"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/crypto_chart_int_4h" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/crypto_chart_interval_group_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crypto_chart_int_1d"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/crypto_chart_int_1d" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crypto_chart_int_1w"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/crypto_chart_int_1w" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crypto_chart_int_1mo"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/crypto_chart_int_1mo" />
    </com.google.android.material.button.MaterialButtonToggleGroup>
</LinearLayout>
