<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/midi_background">

    <!-- Toolbar avec navigation -->
    <LinearLayout
        android:id="@+id/toolbar_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="4dp"
        android:paddingHorizontal="8dp"
        android:background="@color/midi_surface"
        android:elevation="4dp"
        tools:ignore="UselessParent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

            <!-- Bouton retour -->
            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/midi_text_primary"
                android:contentDescription="@string/back" />

            <!-- Spacer pour pousser les tabs à droite -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Tabs de navigation (cachés en mode training) -->
            <HorizontalScrollView
                android:id="@+id/tabs_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginHorizontal="4dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tab_library"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/midi_nav_library"
                        android:textColor="@color/midi_text_secondary"
                        android:textSize="13sp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                    <TextView
                        android:id="@+id/tab_playlists"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/midi_nav_playlists"
                        android:textColor="@color/midi_text_secondary"
                        android:textSize="13sp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                    <TextView
                        android:id="@+id/tab_now_playing"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/midi_nav_now_playing"
                        android:textColor="@color/midi_text_secondary"
                        android:textSize="13sp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                    <TextView
                        android:id="@+id/tab_practice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/midi_nav_practice"
                        android:textColor="?attr/a2uMidiAccent"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Bouton Mode Libre (visible seulement en mode MIDI training) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_free_mode"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="4dp"
                android:text="@string/practice_free_mode"
                android:textSize="11sp"
                android:minWidth="0dp"
                android:paddingHorizontal="12dp"
                android:visibility="gone"
                app:cornerRadius="16dp"
                app:strokeColor="?attr/a2uMidiAccent"
                android:textColor="?attr/a2uMidiAccent"
                tools:visibility="visible" />

            <!-- Sélection des mains (visible seulement en mode deux mains) -->
            <LinearLayout
                android:id="@+id/hand_selection_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginEnd="4dp"
                android:background="@drawable/rounded_container_background"
                android:paddingHorizontal="4dp"
                android:paddingVertical="2dp"
                android:visibility="gone"
                tools:visibility="visible">

                <!-- Bouton main gauche -->
                <ImageButton
                    android:id="@+id/btn_hand_left"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_hand_left"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/midi_text_secondary"
                    android:contentDescription="@string/practice_left_hand_only" />

                <!-- Bouton deux mains -->
                <ImageButton
                    android:id="@+id/btn_hands_both"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_hands_both"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?attr/a2uMidiAccent"
                    android:contentDescription="@string/practice_both_hands" />

                <!-- Bouton main droite -->
                <ImageButton
                    android:id="@+id/btn_hand_right"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_hand_right"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/midi_text_secondary"
                    android:contentDescription="@string/practice_right_hand_only" />

            </LinearLayout>

            <!-- Contrôle du son par main (visible seulement en mode deux mains) -->
            <LinearLayout
                android:id="@+id/hand_sound_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginEnd="4dp"
                android:background="@drawable/rounded_container_background"
                android:paddingHorizontal="4dp"
                android:paddingVertical="2dp"
                android:visibility="gone"
                tools:visibility="visible">

                <!-- Bouton son main gauche -->
                <ImageButton
                    android:id="@+id/btn_hand_left_sound"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_hand_left_sound"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?attr/a2uMidiAccent"
                    android:contentDescription="@string/practice_left_hand_sound" />

                <!-- Bouton son deux mains -->
                <ImageButton
                    android:id="@+id/btn_hands_both_sound"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_hands_both_sound"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?attr/a2uMidiAccent"
                    android:contentDescription="@string/practice_both_hands_sound" />

                <!-- Bouton son main droite -->
                <ImageButton
                    android:id="@+id/btn_hand_right_sound"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_hand_right_sound"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?attr/a2uMidiAccent"
                    android:contentDescription="@string/practice_right_hand_sound" />

            </LinearLayout>

            <!-- Indicateur clavier MIDI externe (caché par défaut) -->
            <ImageButton
                android:id="@+id/btn_midi_keyboard"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_piano_keyboard"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/midi_text_secondary"
                android:visibility="gone"
                android:contentDescription="@string/midi_keyboard_connected"
                tools:visibility="visible" />

            <!-- Bouton menu 3 points -->
            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_more_vert"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/midi_text_primary"
                android:contentDescription="@string/settings" />

    </LinearLayout>

    <!-- Guideline pour séparer falling notes / piano (position ajustable) -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_piano_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.35" />

    <!-- Zone des notes tombantes -->
    <com.Atom2Universe.app.midi.practice.FallingNotesView
        android:id="@+id/falling_notes_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar_container"
        app:layout_constraintBottom_toTopOf="@id/resize_divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Overlay: Titre à gauche + SeekBar avec marqueurs à droite -->
    <LinearLayout
        android:id="@+id/top_overlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        android:padding="6dp"
        android:background="@drawable/bg_title_overlay"
        app:layout_constraintTop_toBottomOf="@id/toolbar_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Titre et instrument -->
        <LinearLayout
            android:id="@+id/title_overlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/txt_track_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/midi_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:maxWidth="160dp"
                android:ellipsize="end"
                tools:text="Fur Elise" />

            <TextView
                android:id="@+id/txt_instrument"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/midi_text_secondary"
                android:textSize="11sp"
                android:maxLines="1"
                android:maxWidth="160dp"
                android:ellipsize="end"
                tools:text="Piano Acoustique" />

        </LinearLayout>

        <!-- SeekBar avec système de marqueurs -->
        <com.Atom2Universe.app.midi.practice.MarkerSeekBarView
            android:id="@+id/marker_seekbar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Score Display (modular, positioned top-right of falling notes) -->
    <com.Atom2Universe.app.midi.practice.scoring.ScoreDisplayView
        android:id="@+id/score_display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="70dp"
        android:layout_marginEnd="8dp"
        android:padding="8dp"
        android:background="@drawable/bg_title_overlay"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar_container"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Poignée de redimensionnement draggable -->
    <com.Atom2Universe.app.midi.practice.ResizeDividerView
        android:id="@+id/resize_divider"
        android:layout_width="0dp"
        android:layout_height="24dp"
        app:layout_constraintTop_toTopOf="@id/guideline_piano_top"
        app:layout_constraintBottom_toTopOf="@id/guideline_piano_top"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Clavier piano -->
    <HorizontalScrollView
        android:id="@+id/piano_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/resize_divider"
        app:layout_constraintBottom_toTopOf="@id/controls_panel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.Atom2Universe.app.midi.practice.InteractivePianoView
            android:id="@+id/piano_view"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:minWidth="800dp" />

    </HorizontalScrollView>

    <!-- Panneau de contrôles pour le mode libre (octaves + instrument) -->
    <LinearLayout
        android:id="@+id/free_mode_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@color/midi_surface_variant"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/controls_panel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible">

        <!-- Ligne 1: Mini-clavier indicateur avec boutons de déplacement -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Bouton déplacer vers les graves -->
            <ImageButton
                android:id="@+id/btn_shift_left"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_chevron_left"
                android:background="@drawable/circle_button_background"
                app:tint="@color/midi_text_primary"
                android:contentDescription="@string/practice_octave_down" />

            <!-- Mini-clavier indicateur -->
            <com.Atom2Universe.app.midi.practice.OctaveRangeIndicatorView
                android:id="@+id/octave_indicator"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp" />

            <!-- Bouton déplacer vers les aigus -->
            <ImageButton
                android:id="@+id/btn_shift_right"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_chevron_right"
                android:background="@drawable/circle_button_background"
                app:tint="@color/midi_text_primary"
                android:contentDescription="@string/practice_octave_up" />

        </LinearLayout>

        <!-- Ligne 2: Nombre d'octaves + Instrument -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Contrôle du nombre d'octaves -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_container_background"
                android:padding="4dp">

                <ImageButton
                    android:id="@+id/btn_octave_count_minus"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_remove"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/midi_text_primary"
                    android:contentDescription="@string/practice_less_octaves" />

                <TextView
                    android:id="@+id/txt_octave_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="64dp"
                    android:gravity="center"
                    android:textColor="@color/midi_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="3 oct." />

                <ImageButton
                    android:id="@+id/btn_octave_count_plus"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_add"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/midi_text_primary"
                    android:contentDescription="@string/practice_more_octaves" />

            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Bouton Record (pour Free Mode) -->
            <ImageButton
                android:id="@+id/btn_record_free_mode"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_record"
                android:background="@drawable/circle_button_background"
                android:scaleType="centerInside"
                android:contentDescription="@string/practice_record" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Sélecteur d'instrument -->
            <LinearLayout
                android:id="@+id/instrument_selector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_container_background"
                android:padding="8dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_music_note"
                    app:tint="?attr/a2uMidiAccent"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no" />

                <TextView
                    android:id="@+id/txt_current_instrument"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/midi_text_primary"
                    android:textSize="13sp"
                    android:maxWidth="180dp"
                    android:ellipsize="end"
                    android:singleLine="true"
                    tools:text="0: Acoustic Grand Piano" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_expand_more"
                    app:tint="@color/midi_text_secondary"
                    android:layout_marginStart="4dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Sheet music view (draggable overlay) -->
    <com.Atom2Universe.app.midi.practice.DraggableSheetMusicContainer
        android:id="@+id/sheet_music_container"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:elevation="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible">

        <com.Atom2Universe.app.midi.practice.SheetMusicView
            android:id="@+id/sheet_music_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp" />

    </com.Atom2Universe.app.midi.practice.DraggableSheetMusicContainer>

    <!-- Panneau de contrôles -->
    <LinearLayout
        android:id="@+id/controls_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@color/midi_surface"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Boutons de contrôle avec timers intégrés -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Bouton Accompagnement (speaker group) -->
            <ImageButton
                android:id="@+id/btn_accompaniment"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_speaker_group"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/a2uMidiAccent"
                android:contentDescription="@string/practice_accompaniment" />

            <!-- Bouton Je Joue (speaker solo) -->
            <ImageButton
                android:id="@+id/btn_i_play"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_speaker_solo"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/midi_text_secondary"
                android:contentDescription="@string/practice_i_play" />

            <!-- Bouton LED clavier (envoyer les notes au clavier externe) -->
            <ImageButton
                android:id="@+id/btn_keyboard_leds"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_piano_keyboard"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/midi_text_secondary"
                android:visibility="gone"
                android:contentDescription="@string/practice_keyboard_leds" />

            <!-- Bouton Mute son LED (lumière sans son sur le clavier) -->
            <ImageButton
                android:id="@+id/btn_mute_led_sound"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_volume_off"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/midi_text_secondary"
                android:visibility="gone"
                android:contentDescription="@string/practice_mute_led_sound" />

            <!-- Bouton Mute synthé interne pour notes utilisateur (son clavier uniquement) -->
            <ImageButton
                android:id="@+id/btn_mute_internal_synth"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_speaker_muted"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/midi_text_secondary"
                android:visibility="gone"
                android:contentDescription="@string/practice_mute_internal_synth" />

            <!-- Temps actuel (entre boutons gauche et play) -->
            <TextView
                android:id="@+id/txt_time_current"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="@color/midi_text_primary"
                android:textSize="13sp"
                android:fontFamily="monospace"
                tools:text="1:23" />

            <!-- Bouton Record (à gauche du Play) -->
            <ImageButton
                android:id="@+id/btn_record"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_record"
                android:background="@drawable/circle_button_background"
                android:scaleType="centerInside"
                android:contentDescription="@string/practice_record" />

            <!-- Bouton Play/Pause (au centre) -->
            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/play_button_background"
                app:tint="@android:color/white"
                android:contentDescription="@string/play"
                android:scaleType="centerInside"
                android:padding="12dp" />

            <!-- Bouton Stop -->
            <ImageButton
                android:id="@+id/btn_stop"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_stop"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/midi_text_primary"
                android:contentDescription="@string/stop" />

            <!-- Temps restant (entre stop et vitesse) -->
            <TextView
                android:id="@+id/txt_time_total"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="@color/midi_text_secondary"
                android:textSize="13sp"
                android:fontFamily="monospace"
                tools:text="-2:22" />

            <!-- Bouton Vitesse avec indicateur -->
            <LinearLayout
                android:id="@+id/speed_control"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:padding="4dp">

                <TextView
                    android:id="@+id/txt_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/practice_speed_max"
                    android:textColor="@color/midi_text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_speed"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_speed"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/midi_text_secondary"
                    android:contentDescription="@string/practice_speed" />

            </LinearLayout>

            <!-- Bouton Retardateur (délai avant démarrage) -->
            <ImageButton
                android:id="@+id/btn_countdown"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_sleep_timer"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/midi_text_secondary"
                android:contentDescription="@string/practice_countdown" />

        </LinearLayout>

        <!-- Anciens éléments cachés pour compatibilité (gardent les IDs) -->
        <SeekBar
            android:id="@+id/seekbar_position"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btn_restart"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            tools:ignore="ContentDescription" />

        <ImageButton
            android:id="@+id/btn_mark"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            tools:ignore="ContentDescription" />

        <ImageButton
            android:id="@+id/btn_goto_mark"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            tools:ignore="ContentDescription" />

        <!-- Slider de vitesse (caché par défaut, affiché au clic) -->
        <LinearLayout
            android:id="@+id/speed_slider_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/practice_speed_min"
                android:textColor="@color/midi_text_secondary"
                android:textSize="11sp" />

            <SeekBar
                android:id="@+id/seekbar_speed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:min="0"
                android:max="9"
                android:progress="9"
                android:progressTint="?attr/a2uMidiAccent"
                android:thumbTint="?attr/a2uMidiAccent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/practice_speed_max"
                android:textColor="@color/midi_text_secondary"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Checkboxes cachés pour compatibilité code (garder les IDs) -->
        <CheckBox
            android:id="@+id/checkbox_accompaniment"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:checked="true" />

        <CheckBox
            android:id="@+id/checkbox_i_play"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:checked="false" />

        <CheckBox
            android:id="@+id/checkbox_note_names"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:checked="true" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
