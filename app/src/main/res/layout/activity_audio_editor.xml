<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1E1E1E"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/audio_editor_back"
                android:src="@drawable/ic_arrow_back"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/audio_editor_title"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

            <ImageButton
                android:id="@+id/btnToggleVisualMode"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/audio_editor_toggle_visual"
                android:src="@drawable/ic_spectrum"
                app:tint="#AAAAAA" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:visibility="gone"
                android:indeterminateTint="#4CAF50" />

        </LinearLayout>

        <!-- File name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvFileName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/audio_editor_no_file"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:ellipsize="middle"
                android:singleLine="true" />

        </LinearLayout>

        <!-- Tracks container (scrollable) -->
        <ScrollView
            android:id="@+id/tracksScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="12dp"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/tracksContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="8dp" />

        </ScrollView>

        <!-- Empty state message -->
        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:gravity="center"
            android:text="@string/audio_editor_no_tracks"
            android:textColor="#555555"
            android:textSize="14sp"
            android:visibility="visible" />

        <!-- Time display -->
        <LinearLayout
            android:id="@+id/timeContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/audio_editor_time_zero"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/audio_editor_time_zero"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- SeekBar -->
        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:max="1000"
            android:progress="0"
            android:progressTint="#4CAF50"
            android:thumbTint="#4CAF50" />

        <!-- Playback controls -->
        <LinearLayout
            android:id="@+id/playbackControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnStop"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/audio_editor_stop"
                android:src="@drawable/ic_stop"
                app:tint="#FFFFFF" />

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginHorizontal="20dp">

                <ImageButton
                    android:id="@+id/btnPlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_button_bg"
                    android:contentDescription="@string/audio_editor_play"
                    android:src="@drawable/ic_play"
                    android:padding="14dp"
                    app:tint="#FFFFFF" />

                <ImageButton
                    android:id="@+id/btnPause"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_button_bg"
                    android:contentDescription="@string/audio_editor_pause"
                    android:src="@drawable/ic_pause"
                    android:padding="14dp"
                    android:visibility="gone"
                    app:tint="#FFFFFF" />

            </FrameLayout>

            <View
                android:layout_width="52dp"
                android:layout_height="52dp" />

        </LinearLayout>

        <!-- Edit toolbar (Copy/Cut/Paste/Delete/Trim + Undo/Redo) -->
        <LinearLayout
            android:id="@+id/editToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/rounded_dialog_bg"
            android:padding="4dp">

            <ImageButton
                android:id="@+id/btnCopy"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/audio_editor_copy"
                android:src="@drawable/ic_content_copy"
                android:enabled="false"
                android:alpha="0.4"
                app:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/btnCut"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/audio_editor_cut"
                android:src="@drawable/ic_content_cut"
                android:enabled="false"
                android:alpha="0.4"
                app:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/btnPaste"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/audio_editor_paste"
                android:src="@drawable/ic_content_paste"
                android:enabled="false"
                android:alpha="0.4"
                app:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/audio_editor_delete"
                android:src="@drawable/ic_delete"
                android:enabled="false"
                android:alpha="0.4"
                app:tint="#FF5252" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="4dp"
                android:background="#444444" />

            <ImageButton
                android:id="@+id/btnTrim"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/audio_editor_trim"
                android:src="@drawable/ic_crop"
                android:enabled="false"
                android:alpha="0.4"
                app:tint="#FFFFFF" />

            <!-- Spacer to push undo/redo to the right -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="4dp"
                android:background="#444444" />

            <ImageButton
                android:id="@+id/btnUndo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/audio_editor_undo"
                android:src="@drawable/ic_undo"
                android:enabled="false"
                android:alpha="0.4"
                app:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/btnRedo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/audio_editor_redo"
                android:src="@drawable/ic_redo"
                android:enabled="false"
                android:alpha="0.4"
                app:tint="#FFFFFF" />

        </LinearLayout>

        <!-- Help text -->
        <TextView
            android:id="@+id/tvSelectionInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginHorizontal="16dp"
            android:text="@string/audio_editor_hint"
            android:textColor="#555555"
            android:textSize="11sp"
            android:gravity="center" />

        <!-- Action buttons -->
        <LinearLayout
            android:id="@+id/actionButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpen"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/audio_editor_open"
                android:textAllCaps="false"
                android:textSize="12sp"
                app:icon="@drawable/ic_folder_open"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:cornerRadius="22dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecord"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:text="@string/audio_editor_record"
                android:textAllCaps="false"
                android:textSize="12sp"
                app:icon="@drawable/ic_mic"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:cornerRadius="22dp"
                app:backgroundTint="#F44336"
                style="@style/Widget.MaterialComponents.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExport"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/audio_editor_export"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:enabled="false"
                app:icon="@drawable/ic_save"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:cornerRadius="22dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Loading overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:background="@drawable/rounded_dialog_bg">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="#4CAF50" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/audio_editor_loading"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

        </LinearLayout>

    </FrameLayout>

    <!-- Recording overlay -->
    <FrameLayout
        android:id="@+id/recordingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F0121212"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <!-- Recording indicator -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/recordingIndicator"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/circle_button_red_bg" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/audio_editor_rec"
                    android:textColor="#F44336"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Recording duration -->
            <TextView
                android:id="@+id/tvRecordingDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/audio_editor_time_zero"
                android:textColor="#FFFFFF"
                android:textSize="48sp"
                android:fontFamily="monospace" />

            <!-- Real-time waveform -->
            <com.Atom2Universe.app.audioeditor.RecordingWaveformView
                android:id="@+id/recordingWaveformView"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="16dp" />

            <!-- Recording controls -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Cancel button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelRecording"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginEnd="16dp"
                    android:text="@string/audio_editor_cancel"
                    android:textAllCaps="false"
                    app:cornerRadius="24dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <!-- Stop recording button -->
                <ImageButton
                    android:id="@+id/btnStopRecording"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/circle_button_red_bg"
                    android:contentDescription="@string/audio_editor_stop_recording"
                    android:src="@drawable/ic_stop"
                    android:padding="20dp"
                    app:tint="#FFFFFF" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
