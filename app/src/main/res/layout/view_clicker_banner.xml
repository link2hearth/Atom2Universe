<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layoutDirection="ltr">

    <!-- ── Bannière principale ───────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/clicker_main_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/crypto_banner_background"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:gravity="center_vertical">

        <!-- APC + Lapin (gauche, weight=1) -->
        <LinearLayout
            android:id="@+id/clicker_left_side"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp">

            <TextView
                android:id="@+id/clicker_apc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="#E2E8F0"
                android:textSize="14sp"
                android:fontFamily="monospace" />

            <com.Atom2Universe.app.crypto.clicker.RabbitSpriteView
                android:id="@+id/clicker_rabbit"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="10dp" />

        </LinearLayout>

        <!-- Atomes (centre, weight=1.4) -->
        <LinearLayout
            android:id="@+id/clicker_atoms_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.4"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/clicker_atoms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="monospace"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Tortue + APS (droite, weight=1) -->
        <LinearLayout
            android:id="@+id/clicker_right_side"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:paddingEnd="16dp">

            <com.Atom2Universe.app.crypto.clicker.TurtleSpriteView
                android:id="@+id/clicker_turtle"
                android:layout_width="60dp"
                android:layout_height="20dp"
                android:layout_marginEnd="4dp"
                android:scaleX="-1" />

            <TextView
                android:id="@+id/clicker_aps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#E2E8F0"
                android:textSize="14sp"
                android:fontFamily="monospace" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Sous-ligne frénésies + boutons Gacha/Shop ── -->
    <LinearLayout
        android:id="@+id/frenzy_subrow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Boîte APC (gauche, compacte) : ×mult  timer  clics -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start|center_vertical">

            <LinearLayout
                android:id="@+id/frenzy_apc_box"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="start|center_vertical"
                android:background="@color/crypto_banner_background"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp">

                <TextView
                    android:id="@+id/frenzy_apc_mult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="×2"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/frenzy_apc_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  30s"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginStart="6dp" />

                <TextView
                    android:id="@+id/frenzy_apc_clicks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  0"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Boutons Gacha ☀ et Shop $ (centre) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/clicker_gacha_btn"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:text="☀"
                android:textSize="17sp"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:padding="0dp"
                android:background="@android:color/transparent"
                android:minWidth="0dp"
                android:minHeight="0dp" />

            <Button
                android:id="@+id/clicker_shop_btn"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:text="$"
                android:textSize="17sp"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:padding="0dp"
                android:background="@android:color/transparent"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:layout_marginStart="16dp" />

        </LinearLayout>

        <!-- Boîte APS (droite, compacte) : ×mult -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical">

            <LinearLayout
                android:id="@+id/frenzy_aps_box"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end|center_vertical"
                android:background="@color/crypto_banner_background"
                android:paddingStart="8dp"
                android:paddingEnd="16dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp">

                <TextView
                    android:id="@+id/frenzy_aps_mult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="×2"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
