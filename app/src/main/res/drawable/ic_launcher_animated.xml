<?xml version="1.0" encoding="utf-8"?>
<!--
  AnimatedVectorDrawable pour l'icône A2U (API 33+).
  Le launcher Pixel (et compatible) joue cette animation au relâchement
  d'un long-press sur l'icône.

  Animations :
  - continents_spin : rotation du globe (translateX 0 → -320dp en 8s)
  - note1/2/3       : les notes montent et s'effacent (durées différentes
                      pour un décalage naturel)
-->
<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:drawable="@drawable/ic_launcher_foreground">

    <!-- Globe spin : 2 tuiles de 160dp = -320dp, linéaire, 8s -->
    <target android:name="continents_spin">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:duration="8000"
                android:propertyName="translateX"
                android:valueFrom="0"
                android:valueTo="-80"
                android:valueType="floatType"
                android:repeatCount="infinite"
                android:repeatMode="restart"
                android:interpolator="@android:interpolator/linear"/>
        </aapt:attr>
    </target>

    <!-- Note 1 (♪) : monte de 41dp, s'efface, 2.4s -->
    <target android:name="note1">
        <aapt:attr name="android:animation">
            <set xmlns:android="http://schemas.android.com/apk/res/android">
                <objectAnimator
                    android:duration="2400"
                    android:propertyName="translateY"
                    android:valueFrom="0"
                    android:valueTo="-41"
                    android:valueType="floatType"
                    android:repeatCount="infinite"
                    android:repeatMode="restart"
                    android:interpolator="@android:interpolator/decelerate_quad"/>
                <objectAnimator
                    android:duration="2400"
                    android:propertyName="alpha"
                    android:valueFrom="1.0"
                    android:valueTo="0.0"
                    android:valueType="floatType"
                    android:repeatCount="infinite"
                    android:repeatMode="restart"
                    android:interpolator="@android:interpolator/accelerate_quad"/>
            </set>
        </aapt:attr>
    </target>

    <!-- Note 2 (♩) : 2.0s (décalage naturel avec note 1) -->
    <target android:name="note2">
        <aapt:attr name="android:animation">
            <set xmlns:android="http://schemas.android.com/apk/res/android">
                <objectAnimator
                    android:duration="2000"
                    android:propertyName="translateY"
                    android:valueFrom="0"
                    android:valueTo="-35"
                    android:valueType="floatType"
                    android:repeatCount="infinite"
                    android:repeatMode="restart"
                    android:interpolator="@android:interpolator/decelerate_quad"/>
                <objectAnimator
                    android:duration="2000"
                    android:propertyName="alpha"
                    android:valueFrom="1.0"
                    android:valueTo="0.0"
                    android:valueType="floatType"
                    android:repeatCount="infinite"
                    android:repeatMode="restart"
                    android:interpolator="@android:interpolator/accelerate_quad"/>
            </set>
        </aapt:attr>
    </target>

    <!-- Note 3 (♫) : 1.7s -->
    <target android:name="note3">
        <aapt:attr name="android:animation">
            <set xmlns:android="http://schemas.android.com/apk/res/android">
                <objectAnimator
                    android:duration="1700"
                    android:propertyName="translateY"
                    android:valueFrom="0"
                    android:valueTo="-28"
                    android:valueType="floatType"
                    android:repeatCount="infinite"
                    android:repeatMode="restart"
                    android:interpolator="@android:interpolator/decelerate_quad"/>
                <objectAnimator
                    android:duration="1700"
                    android:propertyName="alpha"
                    android:valueFrom="1.0"
                    android:valueTo="0.0"
                    android:valueType="floatType"
                    android:repeatCount="infinite"
                    android:repeatMode="restart"
                    android:interpolator="@android:interpolator/accelerate_quad"/>
            </set>
        </aapt:attr>
    </target>

</animated-vector>
