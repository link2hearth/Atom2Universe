<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#880000" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#331A1A" />
            <corners android:radius="28dp" />
            <stroke android:width="1dp" android:color="#441A1A" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#CC0000"
                android:endColor="#880000" />
            <corners android:radius="28dp" />
            <stroke android:width="1dp" android:color="#FF4444" />
        </shape>
    </item>
</selector>
