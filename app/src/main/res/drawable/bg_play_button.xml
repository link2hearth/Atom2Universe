<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow effect -->
    <item>
        <shape android:shape="oval" android:alpha="0.25">
            <solid android:color="?attr/a2uMusicAccent" />
        </shape>
    </item>
    <!-- Main button with margin to create glow -->
    <item android:left="4dp" android:right="4dp" android:top="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="36dp"
                android:centerX="0.3"
                android:centerY="0.3"
                android:startColor="?attr/a2uMusicAccent"
                android:endColor="?attr/a2uMusicAccentDim" />
        </shape>
    </item>
</layer-list>
